---
import '../styles/global.css';
import { faqs, testimonials, featuredTiktok } from '../data/site';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Meditation retreat in Chiang Mai — Vipassana & mindfulness with Master Kaie at Silver Temple. Beginner-friendly, English-speaking. From $47.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="meditation retreat Chiang Mai, vipassana retreat Thailand, mindfulness retreat Chiang Mai, Buddhist meditation retreat Thailand, Master Kaie, 347 Awakening, Silver Temple Chiang Mai" />
    <meta name="author" content="Master Kaie" />
    <meta name="publisher" content="347 Happy Life Happy World" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#1B2D5B" />

    <!-- GEO Tags -->
    <meta name="geo.region" content="TH-50" />
    <meta name="geo.placename" content="Chiang Mai" />
    <meta name="geo.position" content="18.7762;98.9865" />
    <meta name="ICBM" content="18.7762, 98.9865" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://347awakening.com" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="347 Happy Life Happy World" />
    <meta property="og:image" content="https://347awakening.com/images/hero-main.jpg" />
    <meta property="og:image:alt" content="347 Happy Life Happy World — Awakening meditation retreat in Chiang Mai, Thailand" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:type" content="image/jpeg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Awakening meditation & life transformation retreat at Silver Temple, Chiang Mai. Guided by Master Kaie. From $47." />
    <meta name="twitter:site" content="@347_happylifehappyworld" />
    <meta name="twitter:image" content="https://347awakening.com/images/hero-main.jpg" />

    <!-- Canonical -->
    <link rel="canonical" href="https://347awakening.com" />

    <!-- Preload LCP hero background. imagesrcset tells the browser which
         variant to fetch so we don't preload a bigger one than we'll render. -->
    <link
      rel="preload"
      as="image"
      type="image/webp"
      fetchpriority="high"
      href="/images/silver-temple-front-480.webp"
      imagesrcset="/images/silver-temple-front-480.webp 480w, /images/silver-temple-front-800.webp 800w, /images/silver-temple-front.webp 1024w"
      imagesizes="100vw"
    />

    <!-- Fonts. We use Google Fonts but can't inline the CSS (it changes per
         browser). The two things we can do: (1) preconnect to gstatic only —
         googleapis connects for a tiny CSS file and doesn't need a dedicated
         handshake slot; (2) declare &display=swap so text paints in the
         system fallback while the webfont is fetching. -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      media="print" onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "347 Happy Life Happy World",
      "alternateName": "347 Awakening",
      "description": "Awakening meditation & life transformation experience at Srisuphan Silver Temple, Chiang Mai, Thailand. Vipassana, mindfulness & inner coaching with Master Kaie.",
      "url": "https://347awakening.com",
      "telephone": "+66944265297",
      "email": "347happylifehappyworld@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Srisuphan Temple (Wat Sri Suphan), Wua Lai Road",
        "addressLocality": "Chiang Mai",
        "addressRegion": "Chiang Mai",
        "postalCode": "50100",
        "addressCountry": "TH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 18.7787367,
        "longitude": 98.983646
      },
      "hasMap": "https://www.google.com/maps/place/347+Happy+life+meditation+retreat/@18.7787367,98.9810711,17z",
      "priceRange": "$47-$347",
      "currenciesAccepted": "THB, USD",
      "paymentAccepted": "Cash, Bank Transfer",
      "openingHours": "Mo-Su 09:00-17:00",
      "image": [
        "https://347awakening.com/images/hero-main.jpg",
        "https://347awakening.com/images/silver-temple-front.png"
      ],
      "sameAs": [
        "https://web.facebook.com/profile.php?id=61550271392068",
        "https://www.instagram.com/kaie_awaken",
        "https://youtube.com/@kaie347happylife",
        "https://www.tiktok.com/@347_happylifehappyworld"
      ],
      "founder": {
        "@type": "Person",
        "name": "Master Kaie",
        "jobTitle": "Meditation Master for Awakening & a Better Life"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": String(testimonials.length),
        "bestRating": "5"
      },
      "areaServed": [
        { "@type": "City", "name": "Chiang Mai" },
        { "@type": "Country", "name": "Thailand" }
      ],
      "knowsLanguage": ["en", "th"],
      "keywords": "meditation retreat, vipassana, awakening meditation, life transformation, mindfulness, Chiang Mai, Thailand, Silver Temple"
    })} />

    <!-- Structured Data: Course offerings -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "347 Awakening — Life Transformation Experience",
      "description": "Awakening meditation retreat blending Buddhist Vipassana with inner coaching techniques for life transformation in Chiang Mai, Thailand",
      "provider": {
        "@type": "Organization",
        "name": "347 Happy Life Happy World",
        "url": "https://347awakening.com"
      },
      "coursePrerequisites": "No prior meditation experience required",
      "educationalLevel": "Beginner to Advanced",
      "inLanguage": "en",
      "locationCreated": {
        "@type": "Place",
        "name": "Srisuphan Silver Temple",
        "address": "Wua Lai Road, Chiang Mai, Thailand"
      },
      "offers": [
        { "@type": "Offer", "name": "Chanting & Meditation (Master Sawan)", "price": "500", "priceCurrency": "THB", "availability": "https://schema.org/InStock" },
        { "@type": "Offer", "name": "347 Awakening 3 Hours", "price": "47", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
        { "@type": "Offer", "name": "347 Awakening 1 Day", "price": "147", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
        { "@type": "Offer", "name": "347 Awakening 3 Days", "price": "347", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
        { "@type": "Offer", "name": "Private Session 1:1", "price": "77", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
      ]
    })} />

    <!-- Structured Data: FAQPage (generated from the same data the page renders) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />

    <!-- Structured Data: Person (Master Kaie) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Master Kaie",
      "jobTitle": "Meditation Master for Awakening & a Better Life",
      "description": "Founder of 347 Happy Life Happy World. Guided over 800 international students from 38+ countries to awaken their consciousness through meditation.",
      "worksFor": {
        "@type": "Organization",
        "name": "347 Happy Life Happy World"
      },
      "url": "https://347awakening.com",
      "sameAs": [
        "https://www.instagram.com/kaie_awaken",
        "https://www.tiktok.com/@347_happylifehappyworld"
      ]
    })} />

    <!-- Structured Data: WebSite (enables Google sitelinks search box) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "347 Awakening",
      "alternateName": "347 Happy Life Happy World",
      "url": "https://347awakening.com",
      "inLanguage": "en",
      "publisher": { "@type": "Organization", "name": "347 Happy Life Happy World" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://347awakening.com/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Structured Data: Organization (broader than LocalBusiness; helps entity recognition) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "347 Happy Life Happy World",
      "alternateName": "347 Awakening",
      "url": "https://347awakening.com",
      "logo": "https://347awakening.com/favicon.svg",
      "image": "https://347awakening.com/images/hero-main.jpg",
      "email": "347happylifehappyworld@gmail.com",
      "telephone": "+66944265297",
      "foundingDate": "2019",
      "founder": { "@type": "Person", "name": "Master Kaie" },
      "slogan": "Awaken your mind. Transform your life. Create your happy world.",
      "contactPoint": [{
        "@type": "ContactPoint",
        "telephone": "+66944265297",
        "contactType": "customer service",
        "availableLanguage": ["English", "Thai"],
        "areaServed": "Worldwide"
      }],
      "sameAs": [
        "https://web.facebook.com/profile.php?id=61550271392068",
        "https://www.instagram.com/kaie_awaken",
        "https://youtube.com/@kaie347happylife",
        "https://www.tiktok.com/@347_happylifehappyworld"
      ]
    })} />

    <!-- Structured Data: Individual Reviews (Google may show star snippets for each) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "itemListElement": testimonials.map((t, i) => ({
        "@type": "Review",
        "position": i + 1,
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": t.name },
        "reviewBody": t.text,
        "itemReviewed": {
          "@type": "LocalBusiness",
          "name": "347 Happy Life Happy World",
          "image": "https://347awakening.com/images/hero-main.jpg",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Chiang Mai",
            "addressCountry": "TH"
          }
        }
      }))
    })} />

    <!-- Structured Data: VideoObject for featured TikTok -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": "Awakening Meditation with Master Kaie — Silver Temple, Chiang Mai",
      "description": "A glimpse into the 347 Awakening meditation experience at Srisuphan Silver Temple in Chiang Mai, Thailand.",
      "thumbnailUrl": "https://347awakening.com/images/hero-main.jpg",
      "uploadDate": "2025-01-01",
      "contentUrl": `https://www.tiktok.com/@${featuredTiktok.username}/video/${featuredTiktok.videoId}`,
      "embedUrl": `https://www.tiktok.com/embed/v2/${featuredTiktok.videoId}`,
      "publisher": {
        "@type": "Organization",
        "name": "347 Happy Life Happy World",
        "logo": { "@type": "ImageObject", "url": "https://347awakening.com/favicon.svg" }
      }
    })} />

    <!-- Structured Data: BreadcrumbList (helps Google understand site hierarchy) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://347awakening.com" },
        { "@type": "ListItem", "position": 2, "name": "Meditation Retreat Chiang Mai", "item": "https://347awakening.com#courses" }
      ]
    })} />

    <!-- Google Analytics (loaded last in head so it never blocks critical render) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NCM8XJXS9T"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NCM8XJXS9T');
    </script>
  </head>
  <body class="bg-ivory text-body antialiased font-sans">
    <!-- Scroll progress indicator -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

    <slot />

    <!-- Scroll reveal observer + animations -->
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Scroll reveal — adds .visible to .reveal, .gold-line, .lotus-draw
      if (!reduce) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal, .gold-line, .lotus-draw').forEach(el => obs.observe(el));
      }

      // Stat counter — counts up from 0 to data-target when scrolled into view
      const counters = document.querySelectorAll('.stat-counter');
      if (counters.length) {
        const animateCount = (el) => {
          const target = Number(el.dataset.target || el.textContent || 0);
          const suffix = el.dataset.suffix || '';
          if (reduce || !target) {
            el.textContent = target + suffix;
            return;
          }
          const duration = 1500;
          const start = performance.now();
          const tick = (now) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // out-expo easing
            const eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            const current = Math.round(target * eased);
            el.textContent = current + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        const cobs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              animateCount(e.target);
              cobs.unobserve(e.target);
            }
          });
        }, { threshold: 0.6 });
        counters.forEach(c => {
          // Initialize to 0 so it doesn't flash the final number before animation
          c.textContent = '0' + (c.dataset.suffix || '');
          cobs.observe(c);
        });
      }

      // Scroll progress bar
      const bar = document.getElementById('scroll-progress');
      if (bar && !reduce) {
        const onScroll = () => {
          const h = document.documentElement;
          const scrolled = h.scrollTop;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (scrolled / max) * 100 : 0;
          bar.style.width = pct + '%';
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    </script>
  </body>
</html>
