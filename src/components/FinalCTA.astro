---
interface Props {
  wa: string;
  email: string;
}

const { wa, email } = Astro.props;
---

<section class="relative overflow-hidden">
    <!-- Temple background -->
    <div class="absolute inset-0">
      <img
        src="/images/silver-temple-front-800.webp"
        srcset="/images/silver-temple-front-480.webp 480w, /images/silver-temple-front-800.webp 800w, /images/silver-temple-front.webp 1024w"
        sizes="100vw"
        alt=""
        width="1024" height="741"
        class="w-full h-full object-cover" loading="lazy" decoding="async" aria-hidden="true"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0A1530]/92 via-[#0D1B3E]/88 to-[#0A1530]/95"></div>
    </div>

    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden">
      <!-- Golden radial glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[radial-gradient(circle,rgba(197,165,90,0.12),transparent_65%)]"></div>
      <!-- Lotus SVG -->
      <svg class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] opacity-[0.04]" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M100 10 C100 10, 60 40, 50 80 C50 80, 70 60, 100 55 C130 60, 150 80, 150 80 C140 40, 100 10, 100 10Z" fill="#C5A55A"/>
        <path d="M100 10 C100 10, 40 50, 25 90 C25 90, 55 65, 100 58 C145 65, 175 90, 175 90 C160 50, 100 10, 100 10Z" fill="#C5A55A" opacity="0.6"/>
        <path d="M100 10 C100 10, 20 60, 5 100 C5 100, 40 70, 100 62 C160 70, 195 100, 195 100 C180 60, 100 10, 100 10Z" fill="#C5A55A" opacity="0.3"/>
        <ellipse cx="100" cy="105" rx="90" ry="8" fill="#C5A55A" opacity="0.2"/>
      </svg>
      <!-- Side gold lines -->
      <div class="absolute top-20 left-10 w-px h-32 bg-gradient-to-b from-transparent via-deep-calm/20 to-transparent"></div>
      <div class="absolute top-20 right-10 w-px h-32 bg-gradient-to-b from-transparent via-deep-calm/20 to-transparent"></div>
      <div class="absolute bottom-20 left-10 w-px h-32 bg-gradient-to-b from-transparent via-deep-calm/20 to-transparent"></div>
      <div class="absolute bottom-20 right-10 w-px h-32 bg-gradient-to-b from-transparent via-deep-calm/20 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 py-24 md:py-36 text-center">
      <!-- Gold decorative line -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-12 h-px bg-deep-calm/50"></div>
        <svg class="w-5 h-5 text-deep-calm" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <div class="w-12 h-px bg-deep-calm/50"></div>
      </div>

      <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.25em] mb-5">Your Transformation Begins Here</p>
      <h2 class="font-heading text-4xl md:text-6xl font-bold leading-tight mb-6 text-white">Step Into Your<br><span class="text-deep-calm">Awakening</span></h2>
      <p class="text-white/65 text-lg leading-relaxed mb-12 max-w-xl mx-auto">
        Experience awakening meditation and life transformation in Chiang Mai. Whether you're a complete beginner or a seasoned practitioner, your path to a new life is waiting.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booking" class="inline-flex items-center justify-center gap-2.5 bg-deep-calm text-violet-dark px-8 py-4 rounded-full text-lg font-semibold hover:bg-deep-calm-dark hover:text-white transition-all hover:-translate-y-0.5 hover:shadow-xl shadow-lg">
          Book Your Retreat
        </a>
        <a href={`mailto:${email}`} class="inline-flex items-center justify-center gap-2 bg-deep-calm/20 text-deep-calm px-8 py-4 rounded-full text-lg font-semibold border border-deep-calm/30 hover:bg-deep-calm hover:text-violet-dark transition-all">
          Email Us
        </a>
      </div>

      <p class="mt-8 text-white/50 text-sm">
        <a href="/meditation-retreat-chiang-mai" class="underline hover:text-deep-calm transition-colors">Learn more about our Meditation Retreat in Chiang Mai</a>
      </p>

      <!-- Bottom gold line -->
      <div class="flex items-center justify-center gap-3 mt-12">
        <div class="w-20 h-px bg-deep-calm/30"></div>
        <div class="w-2 h-2 bg-deep-calm/40 rounded-full"></div>
        <div class="w-20 h-px bg-deep-calm/30"></div>
      </div>
    </div>
  </section>
