---
import { pathCards } from '../../data/site';
---

<section class="bg-cream-dark py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-xs uppercase tracking-[0.3em] text-gold-ink font-semibold mb-4">Transformational Programs</p>
      <h2 class="font-heading text-4xl md:text-5xl font-semibold text-deep-blue">Find the Path for You</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-5"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {pathCards.map((card) => (
        <a href={card.href} class="group bg-white rounded-card shadow-card overflow-hidden flex flex-col hover:shadow-elevated hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={card.img} alt={card.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 flex flex-col flex-1 text-center">
            <h3 class="font-heading text-xl font-semibold text-deep-blue mb-2">{card.title}</h3>
            <p class="text-body-light text-sm leading-relaxed mb-5 flex-1">{card.body}</p>
            <span class="inline-flex items-center justify-center gap-1.5 text-xs uppercase tracking-wide font-semibold text-gold-ink group-hover:text-gold-ink-dark transition-colors">
              {card.cta}
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
