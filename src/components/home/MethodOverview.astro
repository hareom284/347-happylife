---
import { methodPillars } from '../../data/site';
---

<section class="bg-cream py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Heading -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-xs uppercase tracking-[0.3em] text-gold-ink font-semibold mb-4">The 347 Awakening Method</p>
      <h2 class="font-heading text-4xl md:text-5xl font-semibold text-deep-blue mb-5">
        Body. Mind. Spirit. Aligned.
      </h2>
      <div class="w-16 h-px bg-gold mx-auto mb-5"></div>
      <p class="text-body-light leading-relaxed">
        A unique integration of Eastern wisdom and modern science to help you live a balanced, conscious, and fulfilling life.
      </p>
    </div>

    <!-- Pillars -->
    <div class="grid md:grid-cols-3 gap-10 md:gap-0">
      {methodPillars.map((p, i) => (
        <div class={`text-center px-6 ${i > 0 ? 'md:border-l md:border-oat-border' : ''}`}>
          <div class={`w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6 ${p.icon === 'sun' ? 'bg-gold' : 'bg-royal'}`}>
            {p.icon === 'leaf' && (
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21c0-9 6-15 18-15 0 9-6 15-18 15zm0 0c2.5-5 5.5-8 9-9.5" /></svg>
            )}
            {p.icon === 'lotus' && (
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4 0-7.5-2-9-5 2-1 4-1 6 0-1.5-2.5-1.5-5.5 0-8 1.5 2.5 1.5 5.5 0 8 1.5-3 4.5-5 8-5-1 3.5-3.5 6-6 7.5M12 21c4 0 7.5-2 9-5-2-1-4-1-6 0 1.5-2.5 1.5-5.5 0-8" /></svg>
            )}
            {p.icon === 'sun' && (
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4" /><path stroke-linecap="round" d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1" /></svg>
            )}
          </div>
          <h3 class="font-heading text-2xl font-semibold text-deep-blue mb-3">{p.num} – {p.title}</h3>
          <p class="text-body-light text-sm leading-relaxed mb-5">{p.body}</p>
          <a href={p.href} class="inline-flex items-center gap-1.5 text-xs uppercase tracking-wide font-semibold text-gold-ink hover:text-gold-ink-dark transition-colors">
            Learn More
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
