          width="480" height="259"
          class="w-full h-full object-cover object-[50%_20%] hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-3-400.webp"
          srcset="/images/retreat-3-400.webp 400w, /images/retreat-3-800.webp 800w"
          sizes="(max-width: 768px) 50vw, 25vw"
