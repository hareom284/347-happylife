<section class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10 relative z-30 mb-16">
    <!-- Mobile: 2 columns stacked, Desktop: 4 columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3">
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/hero-main-400.webp"
          srcset="/images/hero-main-400.webp 400w, /images/hero-main-800.webp 800w"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Master Kaie guiding an awakening meditation retreat with international students in Chiang Mai, Thailand"
          width="400" height="400"
          class="w-full h-full object-cover object-[50%_40%] hover:scale-105 transition-transform duration-700"
          decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/silver-temple-front-480.webp"
          srcset="/images/silver-temple-front-480.webp 480w, /images/silver-temple-front-800.webp 800w"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Srisuphan Silver Temple (Wat Sri Suphan) in Chiang Mai — sacred venue for the 347 Awakening meditation retreat"
          width="480" height="347"
          class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-2-480.webp"
          srcset="/images/retreat-2-480.webp 480w, /images/retreat-2-800.webp 800w"
          sizes="(max-width: 768px) 50vw, 25vw"
