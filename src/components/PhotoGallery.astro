---
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10 relative z-30 mb-16">
    <!-- Row 1: 4 images -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 mb-2 md:mb-3">
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/hero-main-400.webp"
          srcset="/images/hero-main-400.webp 400w, /images/hero-main-800.webp 800w"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Master Kaie guiding an awakening meditation retreat with international students in Chiang Mai, Thailand"
          width="400" height="400"
          class="w-full h-full object-cover object-[50%_40%] hover:scale-105 transition-transform duration-700"
          decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-photo-1.webp"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Master Kaie with student sharing a warm embrace at the retreat"
          width="400" height="400"
          class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-photo-2.webp"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Students in meditation practice with Master Kaie at Silver Temple"
          width="400" height="400"
          class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-square relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-photo-3.webp"
          sizes="(max-width: 768px) 50vw, 25vw"
          alt="Group meditation session with international students"
          width="400" height="400"
          class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
    </div>
    <!-- Row 2: 3 images -->
    <div class="grid grid-cols-3 gap-2 md:gap-3">
      <div class="aspect-[4/3] relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-meditation.webp"
          sizes="33vw"
          alt="Student in peaceful seated meditation practice"
          width="400" height="300"
          class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-[4/3] relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-photo-4.webp"
          sizes="33vw"
          alt="Students with 347 Happy Life Happy World banner"
          width="400" height="300"
          class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="aspect-[4/3] relative overflow-hidden rounded-xl md:rounded-2xl shadow-card ethereal">
        <img
          src="/images/retreat-photo-5.webp"
          sizes="33vw"
          alt="Certificate ceremony with monk and international students"
          width="400" height="300"
          class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
          loading="lazy" decoding="async"
        />
      </div>
    </div>
  </section>
