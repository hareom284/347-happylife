---
interface Props {
  waMsg: (course: string) => string;
}

const { waMsg } = Astro.props;
---

<section id="courses" class="scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="text-center mb-16 reveal">
        <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">347 Awakening</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-violet gold-line">Life Transformation Experience</h2>
        <p class="text-warm-charcoal mt-3">Choose your depth of awakening — from a 3-hour journey to a full 3-day transformation</p>
      </div>

      <!-- 3 Main Experience Cards -->
      <div class="grid lg:grid-cols-3 gap-6 mb-12 stagger">
        <!-- 347 Life Reset Experience — 3 Hours -->
        <div class="bg-white rounded-card border border-oat-border shadow-card overflow-hidden card-calm reveal">
          <div class="bg-gradient-to-br from-deep-calm to-deep-calm-dark p-7 text-white">
            <span class="bg-white/20 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">347 Life Reset Experience</span>
            <h3 class="font-heading text-2xl font-bold mt-3">Reset Your Life in 3 Hours</h3>
            <div class="mt-3 flex items-baseline gap-2">
              <span class="text-4xl font-bold">$47</span>
              <span class="opacity-70 text-sm">(1,700 THB)</span>
            </div>
            <p class="text-white/70 text-xs mt-2">Private 1:1 from $77 USD</p>
          </div>
          <div class="p-7">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-warm-silver mb-4">You Will Experience</h4>
            <ul class="space-y-2.5 text-sm text-warm-charcoal mb-6">
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Release Stress</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Clear Your Mind</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Reconnect to Your True Self</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Feel Inner Peace</li>
            </ul>
            <a href={waMsg('347 Life Reset Experience — 3 Hours ($47 / 1,700 THB)')} target="_blank" rel="noopener" class="block w-full text-center bg-deep-calm text-white py-3 rounded-full font-medium hover:bg-deep-calm-dark transition-all text-sm">Book Your Session Now</a>
          </div>
        </div>

        <!-- 1 Day — Most Popular -->
        <div class="bg-white rounded-card border-2 border-violet shadow-elevated overflow-hidden card-calm reveal relative">
          <div class="absolute -top-0 left-0 right-0 bg-violet text-white text-center text-xs font-bold py-1.5 uppercase tracking-widest">Most Popular</div>
          <div class="bg-gradient-to-br from-violet to-violet-dark p-7 pt-10 text-white">
            <span class="bg-white/20 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">Deep Dive</span>
            <h3 class="font-heading text-2xl font-bold mt-3">1 Day</h3>
            <div class="mt-3 flex items-baseline gap-2">
              <span class="text-4xl font-bold">$147</span>
              <span class="opacity-70 text-sm">(5,200 THB)</span>
            </div>
          </div>
          <div class="p-7">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-warm-silver mb-4">What's Included</h4>
            <ul class="space-y-2.5 text-sm text-warm-charcoal mb-6">
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Everything in 3 Hours, plus:</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Deep Vipassana meditation</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Awakening practices</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Life Wheel transformation</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Connect to your true self</li>
            </ul>
            <a href={waMsg('347 Awakening 1 Day ($147 / 5,200 THB)')} target="_blank" rel="noopener" class="block w-full text-center bg-violet text-white py-3 rounded-full font-medium hover:bg-violet-dark transition-all text-sm">Book 1 Day</a>
          </div>
        </div>

        <!-- 3 Days — Full Transformation -->
        <div class="bg-white rounded-card border border-oat-border shadow-card overflow-hidden card-calm reveal">
          <div class="bg-gradient-to-br from-[#0A1530] to-violet-dark p-7 text-white">
            <span class="bg-sky-mist/20 text-sky-mist text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">Full Transformation</span>
            <h3 class="font-heading text-2xl font-bold mt-3">3 Days</h3>
            <div class="mt-3 flex items-baseline gap-2">
              <span class="text-4xl font-bold">$347</span>
              <span class="opacity-70 text-sm">(12,500 THB)</span>
            </div>
          </div>
          <div class="p-7">
            <h4 class="text-xs font-semibold uppercase tracking-widest text-warm-silver mb-4">What's Included</h4>
            <ul class="space-y-2.5 text-sm text-warm-charcoal mb-6">
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Complete 347 awakening journey</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Deep spiritual transformation</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Advanced meditation & Vipassana</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Life purpose & soul work</li>
              <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-violet-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Full life transformation experience</li>
            </ul>
            <a href={waMsg('347 Awakening 3 Days ($347 / 12,500 THB)')} target="_blank" rel="noopener" class="block w-full text-center bg-violet-dark text-white py-3 rounded-full font-medium hover:bg-violet transition-all text-sm">Book 3 Days</a>
          </div>
        </div>
      </div>

      <!-- Private Session + Online -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Private 1:1 -->
        <div class="bg-white rounded-card border-2 border-deep-calm shadow-card p-8 relative">
          <div class="absolute -top-3 left-6 bg-sky-mist text-violet text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Private</div>
          <h3 class="font-heading text-2xl font-bold text-violet mb-1">Private Session (1:1)</h3>
          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-4xl font-bold text-deep-calm font-heading">$77</span>
            <span class="text-warm-charcoal text-sm">(2,500 THB)</span>
          </div>
          <p class="text-warm-silver text-sm mb-5">3 Hours &middot; Personalized awakening experience</p>
          <ul class="space-y-2 text-sm text-warm-charcoal mb-6">
            <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 1-on-1 with Master Kaie</li>
            <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Customized meditation for your needs</li>
            <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Personal energy & blockage discovery</li>
            <li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-deep-calm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Inner coaching & life guidance</li>
          </ul>
          <a href={waMsg('Private 1:1 Session ($77 / 2,500 THB)')} target="_blank" rel="noopener" class="block w-full text-center bg-deep-calm text-white py-3.5 rounded-full font-semibold hover:bg-deep-calm-dark transition-all text-sm">Book Private Session</a>
        </div>

        <!-- Online Course Package -->
        <div class="bg-gradient-to-br from-violet-dark to-[#0A1530] rounded-card p-8 text-white relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(200,220,240,0.08),transparent_50%)]"></div>
          <div class="relative">
            <span class="inline-block bg-white/15 text-sky-mist text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">Online Available</span>
            <h3 class="font-heading text-2xl font-bold mb-2">Online Course Package</h3>
            <p class="text-white/60 text-sm mb-6">Transform from anywhere in the world via WhatsApp or Zoom</p>
            <div class="flex flex-wrap gap-3 mb-6">
              <div class="bg-white/10 rounded-xl px-4 py-3 text-center border border-white/10">
                <span class="block text-xl font-bold">$47</span>
                <span class="text-white/50 text-xs">Basic</span>
              </div>
              <div class="bg-white/10 rounded-xl px-4 py-3 text-center border border-white/10">
                <span class="block text-xl font-bold">$97</span>
                <span class="text-white/50 text-xs">Standard</span>
              </div>
              <div class="bg-white/10 rounded-xl px-4 py-3 text-center border border-white/10">
                <span class="block text-xl font-bold">$147</span>
                <span class="text-white/50 text-xs">Premium</span>
              </div>
            </div>
            <a href={waMsg('Online Course Package — interested to learn more')} target="_blank" rel="noopener" class="block w-full text-center bg-white text-violet py-3.5 rounded-full font-semibold hover:bg-sky-mist-light transition-all text-sm">Ask About Online Courses</a>
          </div>
        </div>
      </div>

      <!-- Location options -->
      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        <div class="bg-soft-aura/40 rounded-2xl p-5 border border-soft-aura text-center">
          <svg class="w-6 h-6 text-deep-calm mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <h4 class="font-semibold text-sm text-violet">On-site</h4>
          <p class="text-warm-charcoal text-xs mt-1">Srisuphan Silver Temple, Chiang Mai</p>
        </div>
        <div class="bg-soft-aura/40 rounded-2xl p-5 border border-soft-aura text-center">
          <svg class="w-6 h-6 text-deep-calm mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <h4 class="font-semibold text-sm text-violet">Meditation Space</h4>
          <p class="text-warm-charcoal text-xs mt-1">Chiang Mai location</p>
        </div>
        <div class="bg-soft-aura/40 rounded-2xl p-5 border border-soft-aura text-center">
          <svg class="w-6 h-6 text-deep-calm mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <h4 class="font-semibold text-sm text-violet">Online</h4>
          <p class="text-warm-charcoal text-xs mt-1">WhatsApp / Zoom worldwide</p>
        </div>
      </div>
    </div>
  </section>
