---
interface Props {
  yt: string;
}

const { yt } = Astro.props;
---

<section id="master-kaie" class="bg-violet-dark text-white scroll-mt-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_80%,rgba(200,169,81,0.08),transparent_50%)]"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 relative">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-sky-mist font-semibold text-xs uppercase tracking-[0.2em] mb-4">Your Guide</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold leading-tight mb-2">Master Kaie</h2>
          <p class="text-sky-mist text-sm uppercase tracking-widest mb-8">Meditation Master for Awakening & a Better Life</p>

          <div class="bg-white/[0.07] rounded-card p-6 border border-white/10 mb-8">
            <p class="text-lg italic leading-relaxed text-white/90 font-heading">
              "Awakening is not about escaping the world — it is about living with light, balance, and higher awareness."
            </p>
            <p class="text-sky-mist font-medium text-sm mt-3">— Master Kaie</p>
          </div>

          <p class="text-white/70 leading-relaxed mb-8">
            Founder of 347 Happy Life Happy World. Guided over 800 international students from 38+ countries to awaken their consciousness and live with peace, clarity, and true happiness.
          </p>

          <div class="flex gap-8">
            <div><span class="text-3xl font-heading font-bold text-sky-mist">800+</span><p class="text-white/50 text-xs mt-1">Students</p></div>
            <div><span class="text-3xl font-heading font-bold text-sky-mist">38+</span><p class="text-white/50 text-xs mt-1">Countries</p></div>
            <div><span class="text-3xl font-heading font-bold text-sky-mist">7+</span><p class="text-white/50 text-xs mt-1">Years</p></div>
          </div>
        </div>

        <!-- YouTube Video Embed -->
        <div>
          <div class="flex justify-center">
            <blockquote class="tiktok-embed" cite="https://www.tiktok.com/@347_happylifehappyworld/video/7484144831330045202" data-video-id="7484144831330045202" style="max-width: 340px;min-width: 280px;">
              <section>
                <a target="_blank" title="@347_happylifehappyworld" href="https://www.tiktok.com/@347_happylifehappyworld?refer=embed">@347_happylifehappyworld</a>
                Ask and answer yourself
                <a title="meditationmaster" target="_blank" href="https://www.tiktok.com/tag/meditationmaster?refer=embed">#meditationmaster</a>
                <a title="chiangmai" target="_blank" href="https://www.tiktok.com/tag/chiangmai?refer=embed">#chiangmai</a>
                <a title="happiness" target="_blank" href="https://www.tiktok.com/tag/happiness?refer=embed">#happiness</a>
                <a title="spirit" target="_blank" href="https://www.tiktok.com/tag/spirit?refer=embed">#spirit</a>
                <a title="mind" target="_blank" href="https://www.tiktok.com/tag/mind?refer=embed">#mind</a>
              </section>
            </blockquote>
          </div>
          <p class="text-center mt-3">
            <a href={yt} target="_blank" rel="noopener" class="text-sky-mist text-sm hover:underline inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              Watch more on YouTube
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TikTok embed (suppress console spam) -->
  <script>
    (function() {
      const origLog = console.log;
      const origWarn = console.warn;
      const filter = (fn) => (...args) => {
        if (args[0] && typeof args[0] === 'string' && (args[0].includes('TikTok') || args[0].includes('SES Removing'))) return;
        fn.apply(console, args);
      };
      console.log = filter(origLog);
      console.warn = filter(origWarn);
      const s = document.createElement('script');
      s.src = 'https://www.tiktok.com/embed.js';
      s.async = true;
      s.onload = () => {
        setTimeout(() => { console.log = origLog; console.warn = origWarn; }, 3000);
      };
      document.body.appendChild(s);
    })();
  </script>
