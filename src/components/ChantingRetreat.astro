---
interface Props {
  waMsg: (course: string) => string;
}

const { waMsg } = Astro.props;
---

<section id="master-sawan" class="bg-violet-dark text-white relative overflow-hidden scroll-mt-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(200,220,240,0.06),transparent_70%)]"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 relative">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-sky-mist font-semibold text-xs uppercase tracking-[0.2em] mb-4">Sacred Practice with Master Sawan</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight mb-6">
            Chanting &<br>Meditation Retreat
          </h2>
          <p class="text-white/70 text-lg leading-relaxed mb-8">
            Experience the harmony of sacred chanting and mindful awareness with Master Sawan. Calm the mind, open your heart, and awaken inner peace through the power of sound and presence.
          </p>
          <div class="flex items-center gap-6 mb-8">
            <div>
              <span class="text-3xl font-heading font-bold text-sky-mist">500</span>
              <span class="text-white/60 ml-1">THB</span>
              <span class="text-white/60 text-sm ml-1">(~$14 USD)</span>
            </div>
            <div class="w-px h-8 bg-white/20"></div>
            <div class="text-white/60 text-sm">2 Hours</div>
          </div>
          <a href={waMsg('Chanting & Meditation Retreat')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-violet px-6 py-3 rounded-full font-semibold hover:bg-sky-mist-light transition-all hover:-translate-y-0.5 hover:shadow-lg">
            Book This Retreat
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2 flex justify-center">
            <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl max-w-[280px]">
              <img
                src="/images/master-sawan.png"
                alt="Master Sawan holding a Certificate of Completion at a sacred temple"
                class="w-full h-auto object-cover max-h-[320px]"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-card p-4 border border-white/10 text-center">
            <h3 class="font-semibold text-sm mb-1">Purify Mind</h3>
            <p class="text-white/50 text-xs">Sacred chanting to purify mind and energy</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-card p-4 border border-white/10 text-center">
            <h3 class="font-semibold text-sm mb-1">Present Moment</h3>
            <p class="text-white/50 text-xs">Reconnect with mindful awareness</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-card p-4 border border-white/10 text-center">
            <h3 class="font-semibold text-sm mb-1">Emotional Balance</h3>
            <p class="text-white/50 text-xs">Deep relaxation and inner harmony</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-card p-4 border border-white/10 text-center">
            <h3 class="font-semibold text-sm mb-1">Peace & Clarity</h3>
            <p class="text-white/50 text-xs">Spiritual connection and insight</p>
          </div>
        </div>
      </div>
    </div>
  </section>
