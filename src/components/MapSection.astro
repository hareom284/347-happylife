---
interface Props {
  mapEmbed: string;
}

const { mapEmbed } = Astro.props;
---

<section class="bg-soft-aura/40 border-y border-soft-aura">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">Location</p>
          <h2 class="font-heading text-3xl font-bold text-violet mb-4">How to Get Here</h2>
          <p class="text-warm-charcoal leading-relaxed mb-6">
            We're located at <strong>Srisuphan Temple (Wat Sri Suphan)</strong> on Wua Lai Road in the heart of Chiang Mai's Old City — famous as the Silver Temple.
          </p>
          <ul class="space-y-4 text-sm text-warm-charcoal">
            <li class="flex items-start gap-3">
              <span class="bg-white rounded-lg p-2 border border-soft-aura shrink-0"><svg class="w-4 h-4 text-deep-calm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></span>
              <span><strong>From Airport:</strong> 15 min by Grab/taxi (~80-100 THB)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="bg-white rounded-lg p-2 border border-soft-aura shrink-0"><svg class="w-4 h-4 text-deep-calm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></span>
              <span><strong>From Old City:</strong> 5 min walk from Chiang Mai Gate</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="bg-white rounded-lg p-2 border border-soft-aura shrink-0"><svg class="w-4 h-4 text-deep-calm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></span>
              <span><strong>Red Songthaew:</strong> Tell the driver "Wua Lai, Wat Sri Suphan" (30-50 THB)</span>
            </li>
          </ul>
        </div>
        <div class="rounded-card overflow-hidden shadow-card border border-oat-border h-80">
          <iframe
            src={mapEmbed}
            width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="Srisuphan Temple Location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
