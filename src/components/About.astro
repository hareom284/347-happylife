<section id="about" class="scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-3xl mx-auto text-center mb-16 reveal">
        <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">Awakening Meditation & Life Transformation</p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6 text-violet gold-line">
          347 Happy Life<br>Happy World
        </h2>
        <p class="text-warm-charcoal text-lg leading-relaxed">
          Do you ever feel lost in your thoughts? Or that your mind never truly rests even when your body does? It is your time to let go of what no longer serves you — and return home to your true self. Through awakening meditation, you will experience a life transformation from within.
        </p>
      </div>

      <!-- The 347 Framework -->
      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-sky-mist-light border-2 border-sky-mist rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-deep-calm text-2xl font-heading font-bold">3</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Dimensions</h3>
          <div class="flex justify-center gap-2 mb-4">
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Body</span>
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Mind</span>
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Spirit</span>
          </div>
          <p class="text-warm-charcoal text-sm leading-relaxed">The three dimensions of human existence working in harmony</p>
        </div>

        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-soft-aura border-2 border-soft-aura-dark rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-violet text-2xl font-heading font-bold">4</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Steps</h3>
          <div class="flex flex-wrap justify-center gap-2 mb-4">
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Precept</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Meditation</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Mindfulness</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Wisdom</span>
          </div>
          <p class="text-warm-charcoal text-sm leading-relaxed">The four steps on the path to awakening</p>
        </div>

        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-soft-aura/20 border-2 border-purple-300 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-violet-dark text-2xl font-heading font-bold">7</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Life Wheels</h3>
          <p class="text-warm-charcoal text-sm leading-relaxed mb-3">The inner journey to true happiness — balancing all seven dimensions of your life</p>
          <p class="text-deep-calm text-sm font-medium">Daily mindfulness + inner coaching</p>
        </div>
      </div>

      <!-- WELLBEING CYCLE -->
      <div class="my-16 max-w-lg mx-auto">
        <h3 class="font-heading text-xl md:text-2xl font-bold text-center text-violet mb-8">The Cycle of Wellbeing</h3>
        <div class="relative">
          <!-- Circular cycle visualization -->
          <div class="bg-white rounded-card border border-soft-aura shadow-card p-8 md:p-10">
            <div class="relative w-full aspect-square max-w-xs mx-auto">
              <!-- Center -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-20 h-20 bg-soft-aura rounded-full flex items-center justify-center border-2 border-violet/20">
                  <span class="font-heading text-sm font-bold text-violet text-center leading-tight">347<br><span class="text-xs uppercase tracking-wider text-body-muted">Method</span></span>
                </div>
              </div>

              <!-- SPIRIT - top -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1">
                <div class="bg-violet text-white px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">SPIRIT</div>
              </div>

              <!-- HEALTHY - top right -->
              <div class="absolute top-[18%] right-0 translate-x-1">
                <div class="bg-morning-sage text-body px-4 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">HEALTHY</div>
              </div>

              <!-- MIND - bottom right -->
              <div class="absolute bottom-[18%] right-0 translate-x-1">
                <div class="bg-sky-mist text-body px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">MIND</div>
              </div>

              <!-- BODY - bottom left -->
              <div class="absolute bottom-[18%] left-0 -translate-x-1">
                <div class="bg-soft-aura text-body px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">BODY</div>
              </div>

              <!-- HAPPY - top left -->
              <div class="absolute top-[18%] left-0 -translate-x-1">
                <div class="bg-deep-calm text-white px-4 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">HAPPY</div>
              </div>

              <!-- Connecting arrows (SVG circle) -->
              <svg class="absolute inset-6 w-[calc(100%-48px)] h-[calc(100%-48px)]" viewBox="0 0 200 200" fill="none">
                <circle cx="100" cy="100" r="85" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="8 4" opacity="0.3"/>
                <!-- Arrow indicators -->
                <path d="M100 15 L105 25 L95 25 Z" fill="#1B2D5B" opacity="0.4" transform="rotate(72, 100, 100)"/>
                <path d="M100 15 L105 25 L95 25 Z" fill="#1B2D5B" opacity="0.4" transform="rotate(144, 100, 100)"/>
                <path d="M100 15 L105 25 L95 25 Z" fill="#1B2D5B" opacity="0.4" transform="rotate(216, 100, 100)"/>
                <path d="M100 15 L105 25 L95 25 Z" fill="#1B2D5B" opacity="0.4" transform="rotate(288, 100, 100)"/>
                <path d="M100 15 L105 25 L95 25 Z" fill="#1B2D5B" opacity="0.4" transform="rotate(360, 100, 100)"/>
              </svg>
            </div>
            <p class="text-center text-body-light text-sm mt-6 leading-relaxed">
              When Spirit, Mind, and Body are aligned through meditation, you become truly <strong class="text-deep-calm">Healthy</strong> and <strong class="text-violet">Happy</strong> — the natural state of awakening.
            </p>
          </div>
        </div>
      </div>

      <!-- 347 PYRAMID — THE PATH OF AWAKENING with Silver Temple -->
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <!-- Full-width Silver Temple background -->
    <div class="absolute inset-0">
      <img src="/images/silver-temple-front.png" alt="Srisuphan Silver Temple, Chiang Mai" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0D1B3E]/92 via-[#0D1B3E]/88 to-[#0D1B3E]/94"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_center,rgba(200,220,240,0.12),transparent_50%)]"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-36">
