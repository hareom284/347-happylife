                  <stop offset="0%" stop-color="#E8D5A3"/>
                  <stop offset="100%" stop-color="#C5A55A"/>
                </linearGradient>
                <linearGradient id="gA" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#D4DAE8" stop-opacity="0.9"/>
                  <stop offset="100%" stop-color="#C8DCF0" stop-opacity="0.8"/>
                </linearGradient>
                <linearGradient id="gL" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#C8DCF0" stop-opacity="0.8"/>
                  <stop offset="100%" stop-color="#D4DAE8" stop-opacity="0.7"/>
                </linearGradient>
                <linearGradient id="gF" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="white" stop-opacity="0.15"/>
                  <stop offset="100%" stop-color="white" stop-opacity="0.08"/>
                </linearGradient>
                <filter id="gl"><feGaussianBlur stdDeviation="8"/></filter>
              </defs>

              <!-- Golden glow at top -->
              <circle cx="200" cy="20" r="35" fill="#C5A55A" opacity="0.15" filter="url(#gl)"/>
              <circle cx="200" cy="22" r="5" fill="#E2C96D" opacity="0.9"/>

              <!-- TIER 1: SPIRIT / MIND / BODY (Gold) -->
              <!-- SPIRIT label above pyramid -->
              <text x="200" y="52" text-anchor="middle" fill="#E2C96D" font-size="16" font-weight="700" font-family="Georgia, serif" letter-spacing="4">SPIRIT</text>

              <!-- Spirit triangle -->
              <polygon points="200,60 155,120 245,120" fill="url(#gS)" stroke="#C5A55A" stroke-width="1.5" opacity="0.9"/>

              <!-- Mind -->
              <polygon points="155,126 128,180 272,180 245,126" fill="url(#gS)" stroke="#C5A55A" stroke-width="1" opacity="0.8"/>
              <text x="200" y="160" text-anchor="middle" fill="#1B2D5B" font-size="15" font-weight="700" font-family="Georgia, serif" letter-spacing="2">MIND</text>

              <!-- Body -->
              <polygon points="128,186 100,240 300,240 272,186" fill="url(#gS)" stroke="#C5A55A" stroke-width="1" opacity="0.7"/>
