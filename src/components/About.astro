              <polygon points="87,294 77,324 323,324 313,294" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.8"/>
              <text x="200" y="316" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Meditation</text>

              <polygon points="76,330 66,360 334,360 324,330" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.7"/>
              <text x="200" y="352" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Mindfulness</text>

              <polygon points="65,366 55,396 345,396 335,366" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.6"/>
              <text x="200" y="388" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Morality</text>

              <!-- AWAKENING label -->
              <text x="395" y="330" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="Inter, sans-serif" letter-spacing="2" opacity="0.8">AWAKENING</text>
              <line x1="340" y1="327" x2="370" y2="327" stroke="white" stroke-width="0.8" opacity="0.3"/>

              <!-- Gold divider -->
              <line x1="48" y1="404" x2="352" y2="404" stroke="#C5A55A" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>

              <!-- TIER 3: LIFE TRANSFORMATION -->
              <polygon points="53,410 48,438 352,438 347,410" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.9"/>
              <text x="200" y="430" text-anchor="middle" fill="#E2C96D" font-size="14" font-weight="700" font-family="Georgia, serif">Life Purpose</text>

              <polygon points="47,444 42,472 358,472 353,444" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.8"/>
              <text x="135" y="464" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500">Holistic Health</text>
              <text x="265" y="464" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500">Self Development</text>

              <rect x="38" y="478" width="324" height="28" rx="4" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.7"/>
              <text x="200" y="497" text-anchor="middle" fill="#C5A55A" font-size="12" font-weight="500">Soul Work</text>

              <!-- TRANSFORMATION label -->
              <text x="405" y="460" text-anchor="middle" fill="#C5A55A" font-size="9" font-weight="700" font-family="Inter, sans-serif" letter-spacing="1.5" opacity="0.8">LIFE</text>
              <text x="405" y="472" text-anchor="middle" fill="#C5A55A" font-size="9" font-weight="700" font-family="Inter, sans-serif" letter-spacing="1">TRANSFORMATION</text>
              <line x1="365" y1="466" x2="385" y2="466" stroke="#C5A55A" stroke-width="0.8" opacity="0.4"/>

              <!-- Foundation -->
              <rect x="28" y="514" width="344" height="34" rx="6" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.5" opacity="0.5"/>
              <text x="200" y="536" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500" opacity="0.8">Health  ·  Emotion Balance  ·  Love Relationship</text>
            </svg>
          </div>
        </div>

        <!-- Right: Description cards -->
        <div class="space-y-4">
          <!-- Alignment card -->
          <div class="bg-white/[0.08] backdrop-blur-md rounded-2xl p-6 md:p-7 border border-white/[0.12] hover:bg-white/[0.12] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-sky-mist/30 to-soft-aura/20 rounded-2xl flex items-center justify-center shrink-0 border border-white/10">
                <svg class="w-6 h-6 text-sky-mist" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="text-white text-lg font-semibold mb-1">Alignment</h4>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2 py-0.5 rounded-full border border-sky-mist/15">Spirit</span>
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2 py-0.5 rounded-full border border-sky-mist/15">Mind</span>
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2 py-0.5 rounded-full border border-sky-mist/15">Body</span>
                </div>
                <p class="text-white/65 text-sm leading-relaxed">Connect with your highest self. When Spirit, Mind, and Body align, you access a state of pure awareness and inner peace.</p>
              </div>
            </div>
          </div>

          <!-- Awakening card -->
          <div class="bg-white/[0.08] backdrop-blur-md rounded-2xl p-6 md:p-7 border border-white/[0.12] hover:bg-white/[0.12] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-deep-calm-light/25 to-soft-aura/15 rounded-2xl flex items-center justify-center shrink-0 border border-white/10">
                <svg class="w-6 h-6 text-sky-mist" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
