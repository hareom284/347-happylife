---
import { philosophy347 } from '../data/site';

const transformations = philosophy347.transformations.items;
const firstSix = transformations.slice(0, 6);
const summit = transformations[6];

// 4 Self-Access steps — pulled from the Philosophy doc with both rich and short descriptions
const selfAccess = [
  {
    name: 'Morality',
    short: 'Clean life',
    body: 'A stable foundation for the mind. When we live with honesty, compassion, and responsibility, the mind becomes lighter and more peaceful.',
    principle: 'Live in a way that allows your mind to rest.',
  },
  {
    name: 'Mindfulness',
    short: 'Aware mind',
    body: 'The ability to observe the present moment with clarity. We notice that thoughts arise, emotions arise, experiences arise — but we are not those thoughts or emotions.',
    principle: 'Awareness creates space between the mind and the observer.',
  },
  {
    name: 'Meditation',
    short: 'Stable mind',
    body: 'The practice of stabilising and calming the mind. Thoughts slow down, awareness expands, and inner clarity appears.',
    principle: 'This is the gateway to deeper insight.',
  },
  {
    name: 'Wisdom',
    short: 'Free mind',
    body: 'Seeing the true nature of life — that everything changes, attachment creates suffering, and peace exists within. The natural result of deep awareness and meditation practice.',
    principle: 'It leads to freedom of the mind.',
  },
];
---

<section id="about" class="scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-3xl mx-auto text-center mb-16 reveal">
        <p class="text-gold-ink font-semibold text-xs uppercase tracking-[0.2em] mb-4">Awakening Meditation & Life Transformation</p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6 text-violet gold-line">
          347 Happy Life<br>Happy World
        </h2>
        <p class="text-warm-charcoal text-lg leading-relaxed">
          Do you ever feel lost in your thoughts? Or that your mind never truly rests even when your body does? It is your time to let go of what no longer serves you — and return home to your true self. Through awakening meditation, you will experience a life transformation from within.
        </p>
      </div>

      <!-- WELLBEING CYCLE -->
      <div class="my-16 max-w-lg mx-auto">
        <h3 class="font-heading text-xl md:text-2xl font-bold text-center text-violet mb-8">The Cycle of Wellbeing</h3>
        <div class="relative">
          <!-- Circular cycle visualization -->
          <div class="bg-white rounded-card border border-soft-aura shadow-card p-8 md:p-10">
            <div class="relative w-full aspect-square max-w-xs mx-auto">
              <!-- Center -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-20 h-20 bg-soft-aura rounded-full flex items-center justify-center border-2 border-violet/20">
                  <span class="font-heading text-sm font-bold text-violet text-center leading-tight">347<br><span class="text-xs uppercase tracking-wider text-body-muted">Method</span></span>
                </div>
              </div>

              <!-- SPIRIT - top -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1">
                <div class="bg-violet text-white px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">SPIRIT</div>
              </div>

              <!-- HEALTHY - top right -->
              <div class="absolute top-[18%] right-0 translate-x-1">
                <div class="bg-morning-sage text-body px-4 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">HEALTHY</div>
              </div>

              <!-- MIND - bottom left -->
              <div class="absolute bottom-[18%] left-0 -translate-x-1">
                <div class="bg-sky-mist text-body px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">MIND</div>
              </div>

              <!-- BODY - bottom right -->
              <div class="absolute bottom-[18%] right-0 translate-x-1">
                <div class="bg-soft-aura text-body px-5 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">BODY</div>
              </div>

              <!-- HAPPY - top left -->
              <div class="absolute top-[18%] left-0 -translate-x-1">
                <div class="bg-gold-ink text-white px-4 py-2.5 rounded-full text-sm font-semibold shadow-card text-center">HAPPY</div>
              </div>

              <!-- Connecting arcs with arrowheads — clockwise: SPIRIT → HEALTHY → BODY → MIND → HAPPY → SPIRIT -->
              <svg class="absolute inset-6 w-[calc(100%-48px)] h-[calc(100%-48px)]" viewBox="0 0 200 200" fill="none">
                <defs>
                  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                    <path d="M 0 0 L 10 5 L 0 10 Z" fill="#1B2D5B" opacity="0.5"/>
                  </marker>
                </defs>

                <!-- Arc: SPIRIT (top, 270°) → HEALTHY (top-right, 342°) -->
                <path d="M 113 16 A 85 85 0 0 1 168 38" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.35" marker-end="url(#arrow)"/>

                <!-- Arc: HEALTHY (342°) → BODY (bottom-right, 54°) -->
                <path d="M 180 55 A 85 85 0 0 1 180 148" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.35" marker-end="url(#arrow)"/>

                <!-- Arc: BODY (54°) → MIND (bottom-left, 126°) -->
                <path d="M 168 163 A 85 85 0 0 1 32 163" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.35" marker-end="url(#arrow)"/>

                <!-- Arc: MIND (126°) → HAPPY (top-left, 198°) -->
                <path d="M 20 148 A 85 85 0 0 1 20 55" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.35" marker-end="url(#arrow)"/>

                <!-- Arc: HAPPY (198°) → SPIRIT (top, 270°) -->
                <path d="M 32 38 A 85 85 0 0 1 87 16" stroke="#1B2D5B" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.35" marker-end="url(#arrow)"/>
              </svg>
            </div>
            <p class="text-center text-body-light text-sm mt-6 leading-relaxed">
              When Spirit, Mind, and Body are aligned through meditation, you become truly <strong class="text-gold-ink">Healthy</strong> and <strong class="text-violet">Happy</strong> — the natural state of awakening.
            </p>
          </div>
        </div>
      </div>

      <!-- 347 PYRAMID — THE PATH OF AWAKENING with Silver Temple -->
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <!-- Full-width Silver Temple background -->
    <div class="absolute inset-0">
      <img
        src="/images/silver-temple-front-800.webp"
        srcset="/images/silver-temple-front-480.webp 480w, /images/silver-temple-front-800.webp 800w, /images/silver-temple-front.webp 1024w"
        sizes="100vw"
        alt="Silver Temple (Wat Sri Suphan) on Wua Lai Road, Chiang Mai — home of the 347 Awakening meditation retreat"
        width="1024" height="741"
        class="w-full h-full object-cover" loading="lazy" decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0D1B3E]/92 via-[#0D1B3E]/88 to-[#0D1B3E]/94"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_center,rgba(200,220,240,0.12),transparent_50%)]"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-36">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-4 py-1.5 text-xs mb-6">
          <img src="/images/silver-temple-sunlight.webp" alt="" width="282" height="179" class="w-5 h-5 rounded-full object-cover" loading="lazy" decoding="async" aria-hidden="true" />
          <span class="text-white/80">Silver Temple, Chiang Mai</span>
        </div>
        <h3 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">The Path of Awakening</h3>
        <p class="text-white/70 mt-4 max-w-xl mx-auto text-base md:text-lg italic font-heading">347 is not just a number — it is a map of human awakening.</p>
        <p class="text-white/45 mt-2 max-w-lg mx-auto text-xs md:text-sm uppercase tracking-[0.2em]">The Sacred Path of Inner Awakening</p>
      </div>

      <div class="grid lg:grid-cols-[1fr_1.1fr] gap-8 lg:gap-14 items-start">

        <!-- Left: Pyramid (clean, no side labels) -->
        <div class="flex justify-center lg:sticky lg:top-24">
          <div class="w-full max-w-[400px]">
            <svg viewBox="0 0 440 560" class="w-full drop-shadow-2xl" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="gS" x1="0.5" y1="0" x2="0.5" y2="1">
                  <stop offset="0%" stop-color="#E8D5A3"/>
                  <stop offset="100%" stop-color="#C5A55A"/>
                </linearGradient>
                <filter id="gl"><feGaussianBlur stdDeviation="8"/></filter>
              </defs>

              <!-- Golden glow at top -->
              <circle cx="200" cy="20" r="35" fill="#C5A55A" opacity="0.15" filter="url(#gl)"/>
              <circle cx="200" cy="22" r="5" fill="#E2C96D" opacity="0.9"/>

              <!-- TIER 1: SPIRIT / MIND / BODY (Gold) -->
              <text x="200" y="52" text-anchor="middle" fill="#E2C96D" font-size="16" font-weight="700" font-family="Georgia, serif" letter-spacing="4">SPIRIT</text>

              <polygon points="200,60 155,120 245,120" fill="url(#gS)" stroke="#C5A55A" stroke-width="1.5" opacity="0.9"/>

              <polygon points="155,126 128,180 272,180 245,126" fill="url(#gS)" stroke="#C5A55A" stroke-width="1" opacity="0.8"/>
              <text x="200" y="160" text-anchor="middle" fill="#1B2D5B" font-size="15" font-weight="700" font-family="Georgia, serif" letter-spacing="2">MIND</text>

              <polygon points="128,186 100,240 300,240 272,186" fill="url(#gS)" stroke="#C5A55A" stroke-width="1" opacity="0.7"/>
              <text x="200" y="220" text-anchor="middle" fill="#1B2D5B" font-size="15" font-weight="700" font-family="Georgia, serif" letter-spacing="2">BODY</text>

              <!-- ALIGNMENT label -->
              <text x="365" y="155" text-anchor="middle" fill="#C5A55A" font-size="10" font-weight="700" font-family="Inter, sans-serif" letter-spacing="2">ALIGNMENT</text>
              <line x1="255" y1="152" x2="320" y2="152" stroke="#C5A55A" stroke-width="0.8" opacity="0.4"/>

              <!-- Gold divider -->
              <line x1="90" y1="250" x2="310" y2="250" stroke="#C5A55A" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>

              <!-- TIER 2: AWAKENING -->
              <polygon points="98,258 88,288 312,288 302,258" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.9"/>
              <text x="200" y="280" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="600" font-family="Inter, sans-serif">Wisdom</text>

              <polygon points="87,294 77,324 323,324 313,294" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.8"/>
              <text x="200" y="316" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Meditation</text>

              <polygon points="76,330 66,360 334,360 324,330" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.7"/>
              <text x="200" y="352" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Mindfulness</text>

              <polygon points="65,366 55,396 345,396 335,366" fill="#1B2D5B" stroke="#C5A55A" stroke-width="0.8" opacity="0.6"/>
              <text x="200" y="388" text-anchor="middle" fill="#E2C96D" font-size="13" font-weight="500" font-family="Inter, sans-serif">Morality</text>

              <!-- AWAKENING label -->
              <text x="395" y="330" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="Inter, sans-serif" letter-spacing="2" opacity="0.8">AWAKENING</text>
              <line x1="340" y1="327" x2="370" y2="327" stroke="white" stroke-width="0.8" opacity="0.3"/>

              <!-- Gold divider -->
              <line x1="48" y1="404" x2="352" y2="404" stroke="#C5A55A" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>

              <!-- TIER 3: LIFE TRANSFORMATION -->
              <polygon points="53,410 48,438 352,438 347,410" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.9"/>
              <text x="200" y="430" text-anchor="middle" fill="#E2C96D" font-size="14" font-weight="700" font-family="Georgia, serif">Life Purpose</text>

              <polygon points="47,444 42,472 358,472 353,444" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.8"/>
              <text x="135" y="464" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500">Holistic Health</text>
              <text x="265" y="464" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500">Self Development</text>

              <rect x="38" y="478" width="324" height="28" rx="4" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.8" opacity="0.7"/>
              <text x="200" y="497" text-anchor="middle" fill="#C5A55A" font-size="12" font-weight="500">Soul Work</text>

              <!-- TRANSFORMATION label -->
              <text x="405" y="460" text-anchor="middle" fill="#C5A55A" font-size="9" font-weight="700" font-family="Inter, sans-serif" letter-spacing="1.5" opacity="0.8">LIFE</text>
              <text x="405" y="472" text-anchor="middle" fill="#C5A55A" font-size="9" font-weight="700" font-family="Inter, sans-serif" letter-spacing="1">TRANSFORMATION</text>
              <line x1="365" y1="466" x2="385" y2="466" stroke="#C5A55A" stroke-width="0.8" opacity="0.4"/>

              <!-- Foundation -->
              <rect x="28" y="514" width="344" height="34" rx="6" fill="#0D1B3E" stroke="#C5A55A" stroke-width="0.5" opacity="0.5"/>
              <text x="200" y="536" text-anchor="middle" fill="#C5A55A" font-size="11" font-weight="500" opacity="0.8">Health  ·  Emotion Balance  ·  Love Relationship</text>
            </svg>
          </div>
        </div>

        <!-- Right: Description cards -->
        <div class="space-y-4">
          <!-- Alignment card -->
          <div class="bg-white/[0.08] backdrop-blur-md rounded-2xl p-6 md:p-7 border border-white/[0.12] hover:bg-white/[0.12] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-deep-calm/30 to-deep-calm-light/20 rounded-2xl flex items-center justify-center shrink-0 border border-deep-calm/20">
                <span class="text-deep-calm-light font-heading font-bold text-xl">3</span>
              </div>
              <div class="flex-1">
                <h4 class="text-white text-lg font-semibold mb-1">Alignment</h4>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <span class="text-xs uppercase tracking-wider text-deep-calm-light/90 bg-deep-calm/15 px-2.5 py-1 rounded-full border border-deep-calm/20">Spirit</span>
                  <span class="text-xs uppercase tracking-wider text-deep-calm-light/90 bg-deep-calm/15 px-2.5 py-1 rounded-full border border-deep-calm/20">Mind</span>
                  <span class="text-xs uppercase tracking-wider text-deep-calm-light/90 bg-deep-calm/15 px-2.5 py-1 rounded-full border border-deep-calm/20">Body</span>
                </div>
                <p class="text-white/65 text-sm leading-relaxed">Connect with your highest self. When Spirit, Mind, and Body align, you access a state of pure awareness and inner peace.</p>
              </div>
            </div>
          </div>

          <!-- Awakening card -->
          <div class="bg-white/[0.08] backdrop-blur-md rounded-2xl p-6 md:p-7 border border-white/[0.12] hover:bg-white/[0.12] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-sky-mist/20 to-soft-aura/10 rounded-2xl flex items-center justify-center shrink-0 border border-sky-mist/15">
                <span class="text-sky-mist font-heading font-bold text-xl">4</span>
              </div>
              <div class="flex-1">
                <h4 class="text-white text-lg font-semibold mb-1">Awakening</h4>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2.5 py-1 rounded-full border border-sky-mist/15">Wisdom</span>
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2.5 py-1 rounded-full border border-sky-mist/15">Meditation</span>
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2.5 py-1 rounded-full border border-sky-mist/15">Mindfulness</span>
                  <span class="text-xs uppercase tracking-wider text-sky-mist/80 bg-sky-mist/10 px-2.5 py-1 rounded-full border border-sky-mist/15">Morality</span>
                </div>
                <p class="text-white/65 text-sm leading-relaxed">The four pillars of Buddhist practice guide your inner transformation — from ethical living to the deepest wisdom.</p>
              </div>
            </div>
          </div>

          <!-- Life Transformation card -->
          <div class="bg-white/[0.08] backdrop-blur-md rounded-2xl p-6 md:p-7 border border-white/[0.12] hover:bg-white/[0.12] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-morning-sage/20 to-soft-aura/10 rounded-2xl flex items-center justify-center shrink-0 border border-morning-sage/15">
                <span class="text-morning-sage font-heading font-bold text-xl">7</span>
              </div>
              <div class="flex-1">
                <h4 class="text-white text-lg font-semibold mb-1">Life Transformation</h4>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Life Purpose</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Holistic Health</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Self Development</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Soul Work</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Emotion Balance</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Love & Relationship</span>
                  <span class="text-xs uppercase tracking-wider text-morning-sage/80 bg-morning-sage/10 px-2.5 py-1 rounded-full border border-morning-sage/15">Health</span>
                </div>
                <p class="text-white/65 text-sm leading-relaxed">Apply your awakening to every dimension of life — purpose, health, relationships, and soul work become one integrated journey.</p>
              </div>
            </div>
          </div>

          <!-- Temple callout -->
          <div class="flex items-center gap-4 bg-white/[0.05] backdrop-blur-sm rounded-2xl p-5 border border-white/[0.08]">
            <img src="/images/silver-temple-sunlight.webp" alt="Silver Temple sunlight" width="282" height="179" class="w-20 h-20 rounded-xl object-cover border border-white/15 shadow-lg" loading="lazy" decoding="async" />
            <div>
              <p class="text-white font-semibold text-sm">Practiced at Silver Temple</p>
              <p class="text-white/45 text-xs mt-1 leading-relaxed">One of Chiang Mai's most sacred temples — entirely handcrafted in silver by local artisans. A place where art and spirituality unite.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- THE 3 ALIGNMENTS — payoff of the pyramid's top tier -->
  <section id="three-alignments" class="scroll-mt-20 bg-violet-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-24">
      <div class="max-w-2xl mx-auto text-center mb-12 reveal">
        <p class="text-deep-calm-light font-semibold text-xs uppercase tracking-[0.2em] mb-4">The 3 Alignments</p>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-tight mb-5">
          Spirit, Mind & Body
        </h2>
        <p class="text-white/70 text-base md:text-lg leading-relaxed">
          True wellbeing begins when all three dimensions of your being are in harmony. Most people live disconnected — the 347 method brings them back into alignment.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto stagger">

        <!-- Body — YELLOW CANDLE (1st) -->
        <div class="group relative rounded-card p-8 pt-10 shadow-card hover:shadow-elevated transition-all duration-500 reveal card-calm overflow-hidden bg-deep-blue border border-white/10 text-center">
          <!-- Warm glow behind candle -->
          <div class="absolute top-8 left-1/2 -translate-x-1/2 w-24 h-24 bg-deep-calm-light/10 rounded-full blur-2xl group-hover:bg-deep-calm-light/20 transition-all duration-700 pointer-events-none"></div>
          <div class="relative z-10">
            <!-- Yellow candle SVG -->
            <div class="mx-auto mb-6 group-hover:scale-105 transition-transform duration-500">
              <svg class="w-16 h-28 mx-auto" viewBox="0 0 64 112" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Flame glow -->
                <ellipse cx="32" cy="22" rx="14" ry="14" fill="#FFD54F" opacity="0.15" class="candle-glow"/>
                <!-- Flame outer -->
                <path d="M32 8c-4 6-8 10-8 16 0 5 3.5 8 8 8s8-3 8-8c0-6-4-10-8-16z" fill="#FF8F00" opacity="0.7"/>
                <!-- Flame inner -->
                <path d="M32 14c-2.5 4-5 7-5 11 0 3.5 2.2 5.5 5 5.5s5-2 5-5.5c0-4-2.5-7-5-11z" fill="#FFD54F"/>
                <!-- Flame core -->
                <path d="M32 19c-1.5 2.5-3 4.5-3 7 0 2 1.3 3.2 3 3.2s3-1.2 3-3.2c0-2.5-1.5-4.5-3-7z" fill="#FFF9C4"/>
                <!-- Wick -->
                <line x1="32" y1="30" x2="32" y2="36" stroke="#555" stroke-width="1.5" stroke-linecap="round"/>
                <!-- Candle body — YELLOW -->
                <rect x="22" y="36" width="20" height="56" rx="3" fill="#FBC02D" stroke="#F9A825" stroke-width="0.5"/>
                <!-- Candle highlight -->
                <rect x="25" y="36" width="6" height="56" rx="2" fill="#FFF176" opacity="0.45"/>
                <!-- Candle base -->
                <rect x="18" y="88" width="28" height="8" rx="4" fill="#C17900"/>
                <!-- Drip detail -->
                <path d="M38 36v8c0 2 3 2 3 0v-8" fill="#FDD835" opacity="0.6"/>
              </svg>
            </div>
            <h3 class="font-heading text-2xl font-bold text-deep-calm-light mb-3">Body</h3>
            <div class="w-12 h-0.5 bg-sacred-yellow/30 mx-auto mb-4"></div>
            <p class="text-white/70 text-sm leading-relaxed">Your physical vessel and gateway to awareness. Through mindful breathing and body awareness, you ground yourself in the present moment and release tension.</p>
          </div>
