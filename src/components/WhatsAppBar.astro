---
interface Props {
  wa: string;
}

const { wa } = Astro.props;
---

<!--
  Mobile-only sticky WhatsApp CTA bar.
  Pill button inside a white container that sits at the bottom edge of the viewport.
  Visible by default so it still appears even if the entry animation is skipped.
-->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden whatsapp-bar">
  <div class="bg-cream border-t border-oat-border px-4 py-3 shadow-elevated">
    <a
      href={wa}
      target="_blank"
      rel="noopener"
      class="flex items-center justify-center gap-2.5 bg-gold text-deep-blue w-full py-3.5 rounded-full font-semibold text-base shadow-lg active:scale-[0.98] transition-transform"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.215zm5.422-6.422" /></svg>
      Join the Journey
    </a>
  </div>
</div>
