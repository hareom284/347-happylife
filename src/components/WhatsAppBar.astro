---
interface Props {
  wa: string;
}

const { wa } = Astro.props;
---

<!--
  Mobile-only sticky WhatsApp CTA bar.
  Pill button inside a white container that sits at the bottom edge of the viewport.
  Visible by default so it still appears even if the entry animation is skipped.
-->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden whatsapp-bar">
  <div class="bg-white border-t border-oat-border px-4 py-3 shadow-elevated">
    <a
      href="/booking"
      class="flex items-center justify-center gap-2.5 bg-deep-calm text-violet-dark w-full py-3.5 rounded-full font-semibold text-base shadow-lg active:scale-[0.98] transition-transform"
    >
      Book Now
    </a>
  </div>
</div>
