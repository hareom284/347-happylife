---
interface Props {
  wa: string;
}

const { wa } = Astro.props;
---

<section class="bg-white border-y border-oat-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="text-center mb-12">
        <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">All Programs at a Glance</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-violet">Pricing Overview</h2>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="rounded-card border border-oat-border overflow-hidden shadow-card">
          <div class="bg-violet-dark text-white px-6 py-3 grid grid-cols-3 text-xs font-semibold uppercase tracking-widest">
            <span>Course</span><span class="text-center">Duration</span><span class="text-right">Price</span>
          </div>
          <div class="divide-y divide-oat-border">
            {[
              { name: "Chanting & Meditation (Master Sawan)", dur: "2 hours", thb: "500", usd: "14" },
              { name: "347 Life Reset Experience — 3 Hours", dur: "3 hours", thb: "1,700", usd: "47" },
              { name: "347 Awakening — 1 Day", dur: "Full day", thb: "5,200", usd: "147", highlight: true },
              { name: "347 Awakening — 3 Days", dur: "3 days", thb: "12,500", usd: "347" },
              { name: "Private Session (1:1)", dur: "3 hours", thb: "2,500", usd: "77" },
            ].map((c) => (
              <div class={`grid grid-cols-3 items-center px-6 py-4 text-sm ${c.highlight ? 'bg-soft-aura/50' : 'hover:bg-ivory'} transition-colors`}>
                <span class="font-medium text-violet">{c.name}</span>
                <span class="text-center text-warm-silver text-xs">{c.dur}</span>
                <span class="text-right">
                  <span class="font-bold text-deep-calm">{c.thb} THB</span>
                  <span class="text-warm-silver text-xs ml-1">(~${c.usd})</span>
                </span>
              </div>
            ))}
          </div>
        </div>
        <p class="text-warm-silver text-xs text-center mt-4">Please wear modest, comfortable clothing. Payment accepted on the day of your session.</p>

        <div class="text-center mt-8">
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white px-7 py-3.5 rounded-full text-base font-semibold hover:bg-[#20bd5a] transition-all hover:-translate-y-0.5 hover:shadow-xl shadow-lg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Book Your Course
          </a>
        </div>
      </div>
    </div>
  </section>
