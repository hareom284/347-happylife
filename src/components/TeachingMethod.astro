---
import { teachingPillars } from '../data/site';
---

<section id="teaching-method" class="scroll-mt-20 bg-ivory">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
    <div class="max-w-3xl mx-auto text-center mb-14 reveal">
      <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">The Kaie Awaken Approach</p>
      <h2 class="font-heading text-4xl md:text-5xl font-bold leading-tight tracking-tight text-violet gold-line mb-6">
        How Master Kaie Teaches
      </h2>
      <p class="text-warm-charcoal text-lg leading-relaxed">
        Unlike traditional meditation that focuses only on technique, Master Kaie guides you through a complete inner journey — understanding the mind, experiencing awareness, and transforming life from within.
      </p>
      <p class="font-heading text-xl md:text-2xl text-violet/80 italic leading-relaxed mt-5">
        Her teaching is simple, profound, and deeply human.
      </p>
    </div>

    <!-- Defining stance: belief vs direct experience -->
    <div class="max-w-3xl mx-auto mb-14 reveal">
      <div class="relative bg-soft-aura/30 border border-soft-aura rounded-card p-7 md:p-9 text-center">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-deep-calm text-white text-[10px] font-bold uppercase tracking-[0.2em] px-3 py-1 rounded-full">Her Stance</span>
        <p class="font-heading text-xl md:text-2xl text-violet leading-relaxed">
          She does not ask you to <em class="not-italic font-semibold">believe</em> anything blindly. <br class="hidden md:block" />
          She invites you to <em class="not-italic font-semibold">observe</em>, <em class="not-italic font-semibold">experience</em>, and awaken through your <em class="not-italic font-semibold">own</em> awareness.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
      {teachingPillars.map((p) => (
        <div class="bg-white rounded-card border border-oat-border shadow-card p-7 hover:shadow-elevated transition-shadow card-calm reveal">
          <div class="flex items-start gap-4 mb-3">
            <span class="font-heading text-3xl font-bold text-deep-calm/70 shrink-0">{p.number}</span>
            <h3 class="font-heading text-xl font-bold text-violet leading-snug pt-1">{p.title}</h3>
          </div>
          <p class="text-warm-charcoal text-sm leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>

    <div class="max-w-2xl mx-auto text-center mt-14">
      <p class="font-heading text-xl md:text-2xl text-violet/80 italic leading-relaxed">
        "Kaie does not simply teach people how to meditate. She guides them to discover the awareness that exists beyond the mind."
      </p>
    </div>
  </div>
</section>
