---
import { navLinks } from '../data/site';

interface Props {
  wa: string;
}

const { wa } = Astro.props;
const path = Astro.url.pathname;

// Active when the link's base path matches the current page.
const isActive = (href: string) => {
  const base = href.split('#')[0];
  if (base === '/') return path === '/';
  return path === base || path.startsWith(base + '/');
};
---

<nav aria-label="Main navigation" class="sticky top-0 z-50 bg-cream/95 backdrop-blur-md border-b border-oat-border/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between gap-4">
    <!-- Logo + wordmark -->
    <a href="/" class="flex items-center gap-3 shrink-0 group" aria-label="347 Awakening home">
      <img src="/images/logo.webp" alt="347 Awakening lotus logo" width="48" height="48" class="w-11 h-11 md:w-12 md:h-12 object-contain shrink-0" />
      <span class="flex flex-col leading-none">
        <span class="font-heading text-2xl md:text-3xl font-semibold text-deep-blue group-hover:text-royal transition-colors">347</span>
        <span class="text-[0.6rem] md:text-xs uppercase tracking-[0.3em] text-royal font-semibold mt-0.5">Awakening</span>
        <span class="text-[0.55rem] md:text-[0.65rem] tracking-wide text-body-muted mt-0.5">Happy Life Happy World</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-6 xl:gap-8 text-sm font-medium text-body">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class={`relative uppercase tracking-wide text-xs xl:text-[0.8rem] transition-colors hover:text-gold-ink ${isActive(link.href) ? 'text-gold-ink' : ''}`}
        >
          {link.label}
          {isActive(link.href) && <span class="absolute -bottom-1.5 left-0 w-full h-px bg-gold"></span>}
        </a>
      ))}
    </div>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-3 shrink-0">
      <a href={wa} target="_blank" rel="noopener" class="hidden sm:inline-flex bg-gold text-white px-5 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wide hover:bg-gold-dark transition-all hover:shadow-lg">
        Join the Journey
      </a>
      <button id="menu-toggle" class="lg:hidden p-2 -mr-2 text-deep-blue" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-oat-border bg-cream px-4 pb-5">
    <div class="flex flex-col gap-0.5 pt-2 text-sm font-medium">
      {navLinks.map((link) => (
        <a href={link.href} class={`py-3 px-2 rounded-lg hover:bg-soft-aura-dark/40 uppercase tracking-wide text-xs ${isActive(link.href) ? 'text-gold-ink' : 'text-body'}`}>{link.label}</a>
      ))}
      <a href={wa} target="_blank" rel="noopener" class="mt-3 bg-gold text-white text-center px-5 py-3 rounded-full text-xs font-semibold uppercase tracking-wide hover:bg-gold-dark transition-all">
        Join the Journey
      </a>
    </div>
  </div>
</nav>

<!-- Mobile menu script -->
<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    const isOpen = !menu?.classList.contains('hidden');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
  menu?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
