---
interface Props {
  wa: string;
  email: string;
  fb: string;
  ig: string;
  yt: string;
  tt: string;
}

const { wa, email, fb, ig, yt, tt } = Astro.props;

const quickLinks = [
  { label: 'About', href: '/about' },
  { label: 'The Method', href: '/method' },
  { label: 'Programs', href: '/programs' },
  { label: 'Retreats', href: '/programs#retreats' },
  { label: 'Membership', href: '/membership' },
];

const resourceLinks = [
  { label: 'Journal', href: '/blog/best-meditation-retreat-chiang-mai' },
  { label: 'FAQ', href: '/programs#faq' },
  { label: 'Contact', href: '/contact' },
  { label: 'Terms & Conditions', href: '#' },
  { label: 'Privacy Policy', href: '#' },
];
---

<footer id="contact" class="bg-deep-blue text-cream scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Logo + wordmark -->
      <div>
        <div class="flex items-center gap-3">
          <img src="/images/logo.webp" alt="347 Awakening lotus logo" width="56" height="56" class="w-14 h-14 object-contain shrink-0" />
          <span class="flex flex-col leading-none">
            <span class="font-heading text-4xl font-semibold text-cream">347</span>
            <span class="text-xs uppercase tracking-[0.35em] text-gold-light font-semibold mt-1">Awakening</span>
            <span class="text-[0.7rem] tracking-wide text-cream/60 mt-1">Happy Life Happy World</span>
          </span>
        </div>
        <p class="text-cream/55 text-sm leading-relaxed mt-5 max-w-xs">
          A sanctuary for conscious leaders to reconnect with peace, clarity, and true awakening.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-gold-light font-semibold mb-5">Quick Links</h3>
        <ul class="space-y-3 text-sm">
          {quickLinks.map((l) => (
            <li><a href={l.href} class="text-cream/70 hover:text-cream transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-gold-light font-semibold mb-5">Resources</h3>
        <ul class="space-y-3 text-sm">
          {resourceLinks.map((l) => (
            <li><a href={l.href} class="text-cream/70 hover:text-cream transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Stay Connected -->
      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-gold-light font-semibold mb-5">Stay Connected</h3>
        <p class="text-cream/60 text-sm leading-relaxed mb-5 max-w-xs">
          Join our community for wisdom, inspiration, and updates.
        </p>
        <div class="flex gap-3">
          <a href={ig} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-gold hover:text-deep-blue transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={fb} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-gold hover:text-deep-blue transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={yt} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-gold hover:text-deep-blue transition-colors" aria-label="YouTube">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href={`mailto:${email}`} class="w-10 h-10 bg-cream/10 rounded-full flex items-center justify-center hover:bg-gold hover:text-deep-blue transition-colors" aria-label="Email">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M3 7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- SEO paragraph (retained) -->
    <div class="mt-14 pt-8 border-t border-cream/10">
      <p class="text-cream/45 text-xs leading-relaxed mb-6 max-w-3xl mx-auto text-center">
        347 Happy Life Happy World is a meditation retreat and life transformation center rooted at the Silver Temple (Wat Sri Suphan) in Chiang Mai, Thailand, with online programs offered worldwide. We guide awakening meditation, vipassana retreats, mindfulness workshops, and conscious-living courses. Master Kaie has guided over 800 students from 38+ countries through Buddhist meditation, inner coaching, and consciousness awakening — helping people align Body, Mind, and Spirit.
      </p>
      <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-cream/55 text-xs">
        <p>&copy; 2026 347 Awakening. All rights reserved.</p>
        <p>Built by <a href="https://hareom284.com" target="_blank" rel="noopener noreferrer" class="text-gold-light hover:text-cream transition-colors">Harry</a></p>
        <p>Happy Life • Happy World</p>
      </div>
    </div>
  </div>
</footer>
