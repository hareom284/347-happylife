---
import { vision } from '../data/site';

interface Props {
  wa: string;
  email: string;
  fb: string;
  ig: string;
  yt: string;
  tt: string;
}

const { wa, email, fb, ig, yt, tt } = Astro.props;
---

<footer id="contact" class="bg-violet-dark text-white scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid md:grid-cols-4 gap-10">
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-4">
            <img src="/images/logo-icon.png" alt="347 Awakening Logo" class="h-16 w-auto object-contain drop-shadow-lg brightness-110" />
            <div>
              <div class="font-heading text-xl font-bold">347 Awakening</div>
              <div class="text-sky-mist text-xs uppercase tracking-widest">Meditation for Awakening</div>
            </div>
          </div>
          <p class="text-white/60 text-sm leading-relaxed max-w-sm">
            Guided by Master Kaie at Srisuphan Temple, Chiang Mai. Awakening through the 347 method of Body-Mind-Spirit harmony.
          </p>
          <div class="flex gap-3 mt-6">
            <a href={fb} target="_blank" rel="noopener noreferrer" class="w-11 h-11 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Facebook">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={ig} target="_blank" rel="noopener noreferrer" class="w-11 h-11 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Instagram">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href={yt} target="_blank" rel="noopener noreferrer" class="w-11 h-11 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="YouTube">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href={tt} target="_blank" rel="noopener noreferrer" class="w-11 h-11 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="TikTok">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.28 8.28 0 005.58 2.17v-3.45a4.85 4.85 0 01-1.99-.43l-.01-4.6z"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h3 class="font-semibold text-sm mb-4 uppercase tracking-widest text-white/50">Contact</h3>
          <ul class="space-y-3 text-sm">
            <li><a href={wa} target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors">WhatsApp: +66 94-426-5297</a></li>
            <li><a href={`mailto:${email}`} class="text-white/70 hover:text-white transition-colors break-all">{email}</a></li>
            <li class="text-white/70">Srisuphan Temple, Wua Lai Rd, Chiang Mai</li>
          </ul>
        </div>

        <div>
          <h3 class="font-semibold text-sm mb-4 uppercase tracking-widest text-white/50">Course Times</h3>
          <ul class="text-white/70 text-sm space-y-2">
            <li>10:00 – 12:00 <span class="text-white/60">(Morning)</span></li>
            <li>14:00 – 16:00 <span class="text-white/60">(Afternoon)</span></li>
            <li>09:00 – 12:00 <span class="text-white/60">(Half-day)</span></li>
            <li>09:00 – 16:00 <span class="text-white/60">(Full day)</span></li>
          </ul>
        </div>
      </div>

      <!-- Brand vision tagline + mission -->
      <div class="border-t border-white/10 mt-12 pt-10 text-center">
        <p class="font-heading text-lg md:text-xl italic text-sky-mist/90 leading-relaxed max-w-2xl mx-auto">
          {vision.tagline}
        </p>
        <p class="text-white/55 text-xs md:text-sm leading-relaxed max-w-2xl mx-auto mt-5">
          <span class="text-white/70 font-semibold uppercase tracking-[0.2em] text-[10px] mr-2">Our Mission</span>
          {vision.mission}
        </p>
      </div>

      <!-- SEO-rich footer content -->
      <div class="mt-10 pt-8 border-t border-white/10">
        <p class="text-white/60 text-xs leading-relaxed mb-6 max-w-3xl mx-auto text-center">
          347 Happy Life Happy World is a meditation retreat and life transformation center located at Srisuphan Silver Temple (Wat Sri Suphan) in Chiang Mai, Thailand. We offer awakening meditation courses, vipassana retreats, mindfulness workshops, and spiritual retreats for international visitors. Our English-speaking meditation master, Master Kaie, has guided over 800 students from 38+ countries through Buddhist meditation, inner coaching, and consciousness awakening programs. Whether you're looking for a meditation retreat in Chiang Mai, a beginner-friendly vipassana course in Thailand, or a private spiritual awakening experience, 347 Awakening welcomes you to transform your life through the ancient wisdom of Body, Mind, and Spirit alignment.
        </p>
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-white/60 text-xs">
          <p>&copy; 2026 347 Awakening. All rights reserved.</p>
          <p>Meditation Retreat at Srisuphan Silver Temple, Chiang Mai, Thailand</p>
        </div>
      </div>
    </div>
  </footer>
