---
interface Props {
  testimonials: { name: string; text: string; time: string }[];
  googleMapsLink: string;
  wa: string;
}

const { testimonials, googleMapsLink, wa } = Astro.props;
---

<section id="testimonials" class="scroll-mt-20 bg-ivory-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="text-center mb-16 reveal">
        <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">Google Reviews</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-violet gold-line">What Our Students Say</h2>
        <div class="flex items-center justify-center gap-2 mt-4">
          <div class="flex items-center gap-1" role="img" aria-label="5.0 stars">
            {[1,2,3,4,5].map(() => (<svg aria-hidden="true" class="w-5 h-5 text-deep-calm" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}
          </div>
          <span class="text-body font-semibold">4.9</span>
          <span class="text-body-muted text-sm">on Google Maps</span>
        </div>
      </div>

      <!-- Featured review -->
      <div class="bg-violet rounded-card p-8 md:p-10 mb-8 relative overflow-hidden reveal">
        <div class="absolute top-4 right-6 text-white/10 font-heading text-[120px] leading-none select-none">"</div>
        <div class="relative">
          <div class="flex items-center gap-1 mb-5" role="img" aria-label="5 out of 5 stars">
            {[1,2,3,4,5].map(() => (<svg aria-hidden="true" class="w-5 h-5 text-deep-calm" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}
          </div>
          <p class="text-white font-heading text-xl md:text-2xl leading-relaxed italic mb-6">"This meditation retreat really challenges you to think deeply about your life and what it means. Even after just one session, my mind calmed down and I could see things more clearly."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
              <span class="text-white font-semibold">J</span>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Joanna J Wilkin</p>
              <div class="flex items-center gap-1.5 text-white/60 text-xs">
                <svg aria-hidden="true" class="w-3 h-3" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Google Review &middot; 7 months ago
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Review cards grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 stagger">
        {testimonials.map((t) => (
          <div class="bg-white rounded-card p-6 border-l-4 border-l-deep-calm border border-oat-border shadow-card card-calm reveal">
            <!-- Quote icon -->
            <div class="text-deep-calm/20 font-heading text-4xl leading-none mb-2 select-none">"</div>
            <p class="text-body-light text-sm leading-relaxed mb-5">{t.text}</p>
            <div class="flex items-center justify-between pt-4 border-t border-oat-border">
              <div class="flex items-center gap-2.5">
                <div class="w-9 h-9 bg-violet/10 rounded-full flex items-center justify-center">
                  <span class="text-violet font-semibold text-sm">{t.name.charAt(0)}</span>
                </div>
                <div>
                  <p class="font-semibold text-sm text-violet">{t.name}</p>
                  <p class="text-body-muted text-xs">{t.time}</p>
                </div>
              </div>
              <svg aria-hidden="true" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            </div>
          </div>
        ))}
      </div>

      <!-- Conversion CTA after testimonials — peak trust moment -->
      <div class="mt-12 bg-violet rounded-card p-8 md:p-10 text-center reveal">
        <p class="font-heading text-2xl md:text-3xl text-white mb-5 leading-snug">
          Ready to experience this for yourself?
        </p>
        <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white px-7 py-3.5 rounded-full text-base font-semibold hover:bg-[#20bd5a] transition-all hover:-translate-y-0.5 hover:shadow-xl shadow-lg">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Book via WhatsApp
        </a>
      </div>

      <!-- Bottom: See all + Leave review -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
        <a href={googleMapsLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white border border-oat-border text-body font-semibold text-sm px-6 py-3 rounded-full shadow-clay hover:shadow-card transition-all">
          <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          See all reviews on Google
          <span class="sr-only"> (opens in new tab)</span>
        </a>
        <a href={googleMapsLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-deep-calm text-violet-dark font-semibold text-sm px-6 py-3 rounded-full hover:bg-deep-calm-dark hover:text-white transition-all">
          Leave a Review
          <span class="sr-only"> on Google Maps (opens in new tab)</span>
        </a>
      </div>
    </div>
  </section>
