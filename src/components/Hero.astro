---
interface Props {
  wa: string;
}

const { wa } = Astro.props;
---

<section class="relative overflow-hidden bg-violet-dark text-white min-h-[90vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-b from-violet-dark/95 via-violet-dark/85 to-violet-dark/95 z-10"></div>
    <div class="absolute inset-0 hero-temple-bg bg-cover bg-center bg-parallax" role="img" aria-label="Silver Temple, Chiang Mai"></div>

    <!-- Floating golden particles -->
    <div class="absolute inset-0 z-10 pointer-events-none overflow-hidden">
      <div class="particle" style="top:15%;left:10%;animation-duration:7s;animation-delay:0s;"></div>
      <div class="particle" style="top:25%;left:80%;animation-duration:9s;animation-delay:1s;width:3px;height:3px;"></div>
      <div class="particle" style="top:60%;left:20%;animation-duration:11s;animation-delay:2s;width:5px;height:5px;"></div>
      <div class="particle" style="top:40%;left:70%;animation-duration:8s;animation-delay:3s;"></div>
      <div class="particle" style="top:75%;left:50%;animation-duration:10s;animation-delay:1.5s;width:3px;height:3px;"></div>
      <div class="particle" style="top:20%;left:45%;animation-duration:12s;animation-delay:4s;width:6px;height:6px;opacity:0.1;"></div>
    </div>

    <div class="relative z-20 max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-32 w-full">
      <div class="max-w-3xl hero-entry">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm mb-8">
          <span class="w-2 h-2 bg-deep-calm-light rounded-full breathe"></span>
          Awakening Meditation Experience, Chiang Mai
        </div>

        <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-3" style="text-shadow: 0 2px 12px rgba(0,0,0,0.5);">
          Awaken Your Life Through <em class="text-sky-mist not-italic">Meditation</em>
        </h1>
        <p class="font-heading text-2xl md:text-3xl font-semibold text-deep-calm tracking-wide mb-6" style="text-shadow: 0 2px 8px rgba(0,0,0,0.4);">
          Happy Life Happy World
        </p>

        <p class="font-heading text-xl md:text-2xl text-sky-mist italic leading-relaxed mb-5 max-w-xl" style="text-shadow: 0 1px 6px rgba(0,0,0,0.4);">
          Awaken your mind. Transform your life. Create your happy world.
        </p>

        <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-4 max-w-xl" style="text-shadow: 0 1px 4px rgba(0,0,0,0.3);">
          A life transformation experience at Chiang Mai's sacred Silver Temple. Discover awakening meditation that blends Buddhist Vipassana with inner coaching — guided by Master Kaie.
        </p>

        <div class="flex items-center gap-4 text-sm text-white/80 mb-10">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-sky-mist" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            800+ international students
          </span>
          <span class="w-1 h-1 bg-white/30 rounded-full"></span>
          <span>38+ countries</span>
          <span class="w-1 h-1 bg-white/30 rounded-full"></span>
          <span>Since 2019</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/booking" class="inline-flex items-center justify-center gap-2.5 bg-deep-calm text-violet-dark px-7 py-4 rounded-full text-lg font-semibold hover:bg-deep-calm-dark hover:text-white transition-all hover:-translate-y-0.5 hover:shadow-xl shadow-lg">
            Book Your Retreat
          </a>
          <a href="#courses" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white px-7 py-4 rounded-full text-lg font-medium border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-0.5">
            Explore Courses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
