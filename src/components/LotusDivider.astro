---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`flex justify-center py-6 md:py-8 lotus-draw ${className}`}>
  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="opacity-60 breathe" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="22" pathLength="1" stroke="#C5A55A" stroke-width="0.5"/>
    <circle cx="24" cy="24" r="15" pathLength="1" stroke="#C5A55A" stroke-width="0.5"/>
    <circle cx="24" cy="24" r="8" pathLength="1" stroke="#C5A55A" stroke-width="0.5"/>
    <circle cx="24" cy="24" r="3" fill="#C5A55A"/>
  </svg>
</div>
