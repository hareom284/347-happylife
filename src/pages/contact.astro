---
import Layout from '../layouts/Layout.astro';
import { Navbar, Footer, WhatsAppBar } from '../components/index.astro';
import { wa, email, social, collaboration } from '../data/site';

const channels = [
  { label: 'WhatsApp', value: '+66 94-426-5297', href: wa, ext: true,
    icon: '<path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/>' },
  { label: 'Email', value: email, href: `mailto:${email}`, ext: false,
    icon: '<path d="M2 4h20v16H2z" fill="none"/><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/>' },
  { label: 'Instagram', value: '@kaie_awaken', href: social.ig, ext: true,
    icon: '<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0 3.675a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>' },
  { label: 'Facebook', value: '347 Happy Life Happy World', href: social.fb, ext: true,
    icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>' },
  { label: 'YouTube', value: '@kaie347happylife', href: social.yt, ext: true,
    icon: '<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>' },
];
---

<Layout title="Contact — Begin Your Awakening Journey | 347 Awakening">
  <Navbar wa={wa} />

  <!-- Page hero -->
  <section class="bg-deep-blue text-cream py-24 md:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold-light font-semibold mb-5">Contact</p>
      <h1 class="font-heading text-5xl md:text-6xl font-semibold mb-6">Begin Your Awakening Journey</h1>
      <p class="text-cream/80 text-lg leading-relaxed max-w-2xl mx-auto">
        We welcome individuals, entrepreneurs, leaders, healers, and seekers from around the world.
      </p>
    </div>
  </section>

  <!-- Contact channels -->
  <section class="bg-cream py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {channels.map((c) => (
          <a href={c.href} target={c.ext ? '_blank' : undefined} rel={c.ext ? 'noopener' : undefined} class="group bg-white rounded-card border border-oat-border/60 p-7 shadow-card hover:shadow-elevated hover:-translate-y-1 transition-all flex items-center gap-4">
            <span class="w-12 h-12 rounded-full bg-royal text-white flex items-center justify-center shrink-0 group-hover:bg-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" set:html={c.icon} />
            </span>
            <span class="min-w-0">
              <span class="block text-xs uppercase tracking-wide text-body-muted font-semibold">{c.label}</span>
              <span class="block text-deep-blue font-medium text-sm truncate">{c.value}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Collaboration -->
  <section class="bg-cream-dark py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold-ink font-semibold mb-4">Collaboration Opportunities</p>
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-deep-blue mb-8">Let's Create a Conscious World Together</h2>
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {collaboration.map((c) => (
          <span class="px-5 py-2.5 rounded-full bg-white border border-oat-border/60 text-sm text-body shadow-clay">{c}</span>
        ))}
      </div>
      <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center bg-gold text-white px-8 py-4 rounded-full text-sm font-semibold uppercase tracking-wide hover:bg-gold-dark transition-all">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer wa={wa} email={email} fb={social.fb} ig={social.ig} yt={social.yt} tt={social.tt} />
  <WhatsAppBar wa={wa} />
</Layout>
