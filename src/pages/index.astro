  <!-- TikTok embed (suppress console spam) -->
  <script>
    (function() {
      const origLog = console.log;
      const origWarn = console.warn;
      const filter = (fn) => (...args) => {
        if (args[0] && typeof args[0] === 'string' && (args[0].includes('TikTok') || args[0].includes('SES Removing'))) return;
        fn.apply(console, args);
      };
      console.log = filter(origLog);
      console.warn = filter(origWarn);
      const s = document.createElement('script');
      s.src = 'https://www.tiktok.com/embed.js';
      s.async = true;
      s.onload = () => {
        setTimeout(() => { console.log = origLog; console.warn = origWarn; }, 3000);
      };
      document.body.appendChild(s);
    })();
  </script>

  <!-- Mobile menu script -->
  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      const isOpen = !menu?.classList.contains('hidden');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
    menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }));
  </script>
