---
import Layout from '../layouts/Layout.astro';
import {
  Navbar, Footer, WhatsAppBar,
  Hero, PhotoGallery, CoreQuestions,
  About, OriginStory, MasterKaie, TeachingMethod, StudentOutcomes,
  ChantingRetreat, CourseCards, PricingOverview,
  Testimonials, FAQ, MapSection, FinalCTA,
  LotusDivider,
} from '../components/index.astro';
import {
  wa, email, social, waMsg,
  mapEmbed, googleMapsLink,
  testimonials, faqs,
} from '../data/site';
---

<Layout title="347 Awakening | Meditation Retreat Chiang Mai — Life Transformation at Silver Temple, Thailand">

  <Navbar wa={wa} />
  <Hero wa={wa} />
  <PhotoGallery />
  <CoreQuestions />
  <About />
  <LotusDivider />
  <ChantingRetreat waMsg={waMsg} />
  <CourseCards waMsg={waMsg} />
  <PricingOverview wa={wa} />
  <LotusDivider />
  <OriginStory />
  <MasterKaie yt={social.yt} />
  <TeachingMethod />
  <StudentOutcomes />
  <Testimonials testimonials={testimonials} googleMapsLink={googleMapsLink} wa={wa} />
  <LotusDivider />
  <FAQ faqs={faqs} />
  <FinalCTA wa={wa} email={email} />
  <MapSection mapEmbed={mapEmbed} />
  <Footer wa={wa} email={email} fb={social.fb} ig={social.ig} yt={social.yt} tt={social.tt} />
  <WhatsAppBar wa={wa} />

</Layout>
