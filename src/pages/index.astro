---
import Layout from '../layouts/Layout.astro';

const wa = 'https://wa.me/66944265297';
const waMsg = (course: string) => `https://wa.me/66944265297?text=${encodeURIComponent(`Hello, I'm interested in the ${course}. Could you help me book?`)}`;
const fb = 'https://web.facebook.com/profile.php?id=61550271392068';
const ig = 'https://www.instagram.com/kaie_awaken';
const yt = 'https://youtube.com/@kaie347happylife';
const email = '347happylifehappyworld@gmail.com';
const mapEmbed = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3777.5!2d98.9865!3d18.7762!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sSrisuphan+Temple!5e0!3m2!1sen!2sth!4v1';

const testimonials = [
  { name: "Sarah M.", country: "Australia", flag: "🇦🇺", text: "Master Kaie's guidance helped me find a peace I didn't know existed within me. The 347 method is truly transformative.", course: "Private 1:1" },
  { name: "Thomas B.", country: "Germany", flag: "🇩🇪", text: "I've attended meditation retreats across Asia, and this was the most impactful. The combination of coaching and meditation is unique.", course: "Special Package" },
  { name: "Yuki T.", country: "Japan", flag: "🇯🇵", text: "Even as a complete beginner, I felt welcomed and guided every step. I left with tools I use daily.", course: "Beginner" },
  { name: "Marie L.", country: "France", flag: "🇫🇷", text: "The Vipassana day retreat changed my perspective on life. Master Kaie has a gift for making deep teachings accessible.", course: "Vipassana Full Day" },
  { name: "David K.", country: "USA", flag: "🇺🇸", text: "I came skeptical and left awakened. The 347 approach bridges ancient wisdom with practical modern life.", course: "Advanced" },
];

const faqs = [
  { q: "Do I need meditation experience?", a: "Not at all! Our Beginner course is designed for complete newcomers. We also have Intermediate and Advanced courses for experienced practitioners. Master Kaie adapts guidance to your level." },
  { q: "What language is instruction in?", a: "All courses are taught in English by Master Kaie, who has guided over 800 international students." },
  { q: "What should I wear?", a: "Please wear modest, comfortable clothing — preferably white or light-colored. Loose pants and a comfortable top work well. We practice sitting, walking, and lying meditation." },
  { q: "What's included in the price?", a: "All courses include meditation instruction, guided practice, course materials, and tea/water. The Private and Small Group packages also include 1 month of follow-up guidance." },
  { q: "How do I get to Srisuphan Temple?", a: "Srisuphan Temple (Wat Sri Suphan) is located on Wua Lai Road in Chiang Mai Old City, about 15 minutes from Chiang Mai International Airport. You can take a red songthaew, Grab taxi, or tuk-tuk." },
  { q: "Can I join online?", a: "Yes! We offer online sessions via WhatsApp or Zoom for those who cannot visit Chiang Mai in person. Contact us to arrange your online session." },
  { q: "What is the cancellation policy?", a: "Free cancellation up to 24 hours before your scheduled session. For Private/Group bookings, please notify us 48 hours in advance for a full refund." },
  { q: "Is accommodation or food included?", a: "Accommodation and meals are not included in the course price. We can recommend nearby guesthouses and restaurants in the Wua Lai area. Chiang Mai has excellent affordable options." },
  { q: "How do I book?", a: "Simply click any 'Book Now' button to message us on WhatsApp. We'll confirm your date, time, and course. Payment is made on the day of your session." },
];
---

<Layout title="347 Happy Life Happy World | Awakening Meditation & Life Transformation in Chiang Mai">

  <!-- NAVIGATION -->
  <nav class="sticky top-0 z-50 bg-ivory/95 backdrop-blur-md border-b border-oat-border/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-10 h-10 bg-violet rounded-full flex items-center justify-center group-hover:bg-deep-calm-dark transition-colors">
          <span class="text-white text-xs font-bold tracking-tight">347</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-heading text-lg font-semibold text-violet leading-none">Happy Life</span>
          <span class="block text-[10px] uppercase tracking-[0.2em] text-body-muted font-medium">Happy World</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-7 text-sm font-medium text-body">
        <a href="#about" class="hover:text-deep-calm transition-colors">About</a>
        <a href="#courses" class="hover:text-deep-calm transition-colors">Courses</a>
        <a href="#vipassana" class="hover:text-deep-calm transition-colors">Vipassana</a>
        <a href="#private" class="hover:text-deep-calm transition-colors">Private</a>
        <a href="#master-kaie" class="hover:text-deep-calm transition-colors">Master Kaie</a>
        <a href="#testimonials" class="hover:text-deep-calm transition-colors">Reviews</a>
        <a href="#faq" class="hover:text-deep-calm transition-colors">FAQ</a>
      </div>

      <div class="flex items-center gap-3">
        <a href={wa} target="_blank" rel="noopener" class="bg-deep-calm text-white px-5 py-2.5 rounded-full text-sm font-medium hover:bg-deep-calm-dark-dark transition-all hover:shadow-lg">
          Book Now
        </a>
        <button id="menu-toggle" class="lg:hidden p-2 -mr-2" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden lg:hidden border-t border-oat-border px-4 pb-4">
      <div class="flex flex-col gap-1 pt-2 text-sm font-medium">
        <a href="#about" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">About</a>
        <a href="#courses" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">Courses</a>
        <a href="#vipassana" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">Vipassana</a>
        <a href="#private" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">Private</a>
        <a href="#master-kaie" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">Master Kaie</a>
        <a href="#testimonials" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">Reviews</a>
        <a href="#faq" class="py-2.5 px-2 hover:bg-soft-aura-dark/30 rounded-lg">FAQ</a>
      </div>
    </div>
  </nav>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden bg-violet-dark text-white min-h-[90vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-b from-violet-dark/90 via-violet-dark/70 to-violet-dark/90 z-10"></div>
    <div class="absolute inset-0 bg-[url('/images/silver-temple-front.png')] bg-cover bg-center"></div>

    <div class="relative z-20 max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-32 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm mb-8">
          <span class="w-2 h-2 bg-deep-calm-light rounded-full animate-pulse"></span>
          Awakening Meditation Experience, Chiang Mai
        </div>

        <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-6">
          Awaken Your Life Through <em class="text-sky-mist not-italic">Meditation</em>
        </h1>

        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-4 max-w-xl">
          A life transformation experience at Chiang Mai's sacred Silver Temple. Discover awakening meditation that blends Buddhist Vipassana with inner coaching — guided by Master Kaie.
        </p>

        <div class="flex items-center gap-4 text-sm text-white/60 mb-10">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-sky-mist" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            800+ international students
          </span>
          <span class="w-1 h-1 bg-white/30 rounded-full"></span>
          <span>38+ countries</span>
          <span class="w-1 h-1 bg-white/30 rounded-full"></span>
          <span>Since 2019</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white px-7 py-4 rounded-full text-lg font-semibold hover:bg-[#20bd5a] transition-all hover:-translate-y-0.5 hover:shadow-xl shadow-lg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Book via WhatsApp
          </a>
          <a href="#courses" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white px-7 py-4 rounded-full text-lg font-medium border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-0.5">
            Explore Courses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PHOTO GALLERY (Airbnb-style) ==================== -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 -mt-12 relative z-30 mb-16">
    <div class="grid grid-cols-4 grid-rows-2 gap-2 h-72 md:h-96 rounded-card overflow-hidden shadow-elevated">
      <!-- Large: Hero image from Instagram -->
      <div class="col-span-2 row-span-2 relative group overflow-hidden">
        <img src="/images/hero-main.jpg" alt="347 Happy Life Happy World — Awakening meditation & life transformation experience in Chiang Mai" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4">
          <span class="bg-white/90 backdrop-blur-sm text-body text-xs font-medium px-3 py-1.5 rounded-full shadow-sm">Awakening Meditation & Life Transformation</span>
        </div>
      </div>
      <!-- International group -->
      <div class="relative overflow-hidden group">
        <img src="/images/retreat-3.jpg" alt="International meditation group with Master Kaie — students from around the world" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <!-- Master Kaie with student -->
      <div class="relative overflow-hidden group">
        <img src="/images/retreat-2.jpg" alt="Master Kaie with student at Srisuphan Temple, Chiang Mai" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <!-- Temple meditation session -->
      <div class="relative overflow-hidden group">
        <img src="/images/retreat-temple-session.png" alt="Awakening meditation session at Srisuphan Silver Temple, Chiang Mai" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <!-- Group meditation -->
      <div class="relative overflow-hidden group">
        <img src="/images/retreat-meditation.png" alt="Group meditation — life transformation experience in Chiang Mai" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ==================== 3 CORE QUESTIONS ==================== -->
  <section class="bg-gradient-to-b from-sky-mist-light/50 to-ivory">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-20 md:py-28 text-center">
      <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-8">The Questions That Begin Your Awakening</p>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white/80 backdrop-blur-sm rounded-card p-8 border border-soft-aura shadow-card hover:shadow-elevated transition-shadow">
          <div class="w-14 h-14 bg-soft-aura rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-violet italic mb-3">"Who am I?"</h3>
          <p class="text-body-light text-sm leading-relaxed">Discover your true self beyond the roles, labels, and stories you've been told.</p>
        </div>
        <div class="bg-white/80 backdrop-blur-sm rounded-card p-8 border border-soft-aura shadow-card hover:shadow-elevated transition-shadow">
          <div class="w-14 h-14 bg-soft-aura rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-violet italic mb-3">"Why was I born on this earth?"</h3>
          <p class="text-body-light text-sm leading-relaxed">Understand your purpose and the deeper meaning behind your existence.</p>
        </div>
        <div class="bg-white/80 backdrop-blur-sm rounded-card p-8 border border-soft-aura shadow-card hover:shadow-elevated transition-shadow">
          <div class="w-14 h-14 bg-soft-aura rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-violet italic mb-3">"What is my mission?"</h3>
          <p class="text-body-light text-sm leading-relaxed">Awaken to the unique path and contribution only you can make in this world.</p>
        </div>
      </div>
      <p class="font-heading text-xl md:text-2xl text-violet/80 italic max-w-2xl mx-auto leading-relaxed">
        These are the questions that begin your awakening. Through the 347 method, you will find the answers within.
      </p>
    </div>
  </section>

  <!-- ==================== TRUST BAR ==================== -->
  <section class="border-y border-oat-border bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6">
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14 text-center">
        <div>
          <div class="text-2xl md:text-3xl font-heading font-bold text-deep-calm">800+</div>
          <div class="text-xs uppercase tracking-widest text-warm-silver mt-1">Students Guided</div>
        </div>
        <div class="w-px h-10 bg-oat-border hidden md:block"></div>
        <div>
          <div class="text-2xl md:text-3xl font-heading font-bold text-deep-calm">38+</div>
          <div class="text-xs uppercase tracking-widest text-warm-silver mt-1">Countries</div>
        </div>
        <div class="w-px h-10 bg-oat-border hidden md:block"></div>
        <div>
          <div class="flex items-center justify-center gap-1 text-violet-light">
            {[1,2,3,4,5].map(() => (<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}
          </div>
          <div class="text-xs uppercase tracking-widest text-warm-silver mt-1">5.0 Rating</div>
        </div>
        <div class="w-px h-10 bg-oat-border hidden md:block"></div>
        <div>
          <div class="text-2xl md:text-3xl font-heading font-bold text-deep-calm">7+</div>
          <div class="text-xs uppercase tracking-widest text-warm-silver mt-1">Years Teaching</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT / INTRO ==================== -->
  <section id="about" class="scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-deep-calm font-semibold text-xs uppercase tracking-[0.2em] mb-4">Awakening Meditation & Life Transformation</p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6 text-violet">
          347 Happy Life<br>Happy World
        </h2>
        <p class="text-warm-charcoal text-lg leading-relaxed">
          Do you ever feel lost in your thoughts? Or that your mind never truly rests even when your body does? It is your time to let go of what no longer serves you — and return home to your true self. Through awakening meditation, you will experience a life transformation from within.
        </p>
      </div>

      <!-- The 347 Framework -->
      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-sky-mist-light border-2 border-sky-mist rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-deep-calm text-2xl font-heading font-bold">3</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Dimensions</h3>
          <div class="flex justify-center gap-2 mb-4">
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Body</span>
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Mind</span>
            <span class="bg-soft-aura/40 text-deep-calm text-sm font-medium px-3 py-1 rounded-full border border-soft-aura">Spirit</span>
          </div>
          <p class="text-warm-charcoal text-sm leading-relaxed">The three dimensions of human existence working in harmony</p>
        </div>

        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-soft-aura border-2 border-soft-aura-dark rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-violet text-2xl font-heading font-bold">4</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Steps</h3>
          <div class="flex flex-wrap justify-center gap-2 mb-4">
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Precept</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Meditation</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Mindfulness</span>
            <span class="bg-soft-aura text-violet text-sm font-medium px-3 py-1 rounded-full border border-soft-aura-dark">Wisdom</span>
          </div>
          <p class="text-warm-charcoal text-sm leading-relaxed">The four steps on the path to awakening</p>
        </div>

        <div class="bg-white rounded-card border border-oat-border shadow-card p-8 text-center hover:shadow-elevated transition-shadow">
          <div class="w-16 h-16 bg-soft-aura/20 border-2 border-purple-300 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <span class="text-violet-dark text-2xl font-heading font-bold">7</span>
          </div>
          <h3 class="font-heading text-2xl font-bold mb-3 text-violet">Life Wheels</h3>
          <p class="text-warm-charcoal text-sm leading-relaxed mb-3">The inner journey to true happiness — balancing all seven dimensions of your life</p>
          <p class="text-deep-calm text-sm font-medium">Daily mindfulness + inner coaching</p>
        </div>
      </div>

      <!-- WELLBEING CYCLE -->
      <div class="my-16 max-w-lg mx-auto">
        <h3 class="font-heading text-xl md:text-2xl font-bold text-center text-violet mb-8">The Cycle of Wellbeing</h3>
        <div class="relative">
          <!-- Circular cycle visualization -->
          <div class="bg-white rounded-card border border-soft-aura shadow-card p-8 md:p-10">
            <div class="relative w-full aspect-square max-w-xs mx-auto">
