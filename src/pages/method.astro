---
import Layout from '../layouts/Layout.astro';
import { Navbar, Footer, WhatsAppBar } from '../components/index.astro';
import {
  wa, email, social,
  methodAlignment, methodAwakening, methodTransformation,
} from '../data/site';
---

<Layout title="The 347 Method — The Core Framework of Transformation">
  <Navbar wa={wa} />

  <!-- Page hero -->
  <section class="bg-deep-blue text-cream py-24 md:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold-light font-semibold mb-5">The 347 Method</p>
      <h1 class="font-heading text-5xl md:text-6xl font-semibold mb-6">The Core Framework of Transformation</h1>
      <p class="text-cream/80 text-lg leading-relaxed max-w-2xl mx-auto">
        A complete system for everyday awakening — integrating Eastern wisdom and modern science across Body, Mind, and Spirit.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-9 text-xs uppercase tracking-wide font-semibold">
        <a href="#alignment" class="px-4 py-2 rounded-full border border-cream/30 hover:bg-cream/10 transition-colors">3 · Alignment</a>
        <a href="#awakening" class="px-4 py-2 rounded-full border border-cream/30 hover:bg-cream/10 transition-colors">4 · Awakening</a>
        <a href="#transformation" class="px-4 py-2 rounded-full border border-cream/30 hover:bg-cream/10 transition-colors">7 · Transformation</a>
      </div>
    </div>
  </section>

  <!-- 3 - Alignment -->
  <section id="alignment" class="bg-cream py-20 md:py-24 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-5 mb-12">
        <span class="font-heading text-6xl md:text-7xl text-gold leading-none">{methodAlignment.num}</span>
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-semibold text-deep-blue">{methodAlignment.title}</h2>
          <p class="text-gold-ink text-sm uppercase tracking-wide font-semibold mt-1">{methodAlignment.subtitle}</p>
        </div>
      </div>
      <p class="text-body-light leading-relaxed max-w-2xl mb-10">{methodAlignment.intro}</p>
      <div class="grid md:grid-cols-3 gap-6">
        {methodAlignment.items.map((it) => (
          <div class="bg-white rounded-card border border-oat-border/60 p-7 shadow-card">
            <h3 class="font-heading text-xl font-semibold text-deep-blue mb-3">{it.name}</h3>
            <p class="text-body-light text-sm leading-relaxed">{it.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4 - Awakening -->
  <section id="awakening" class="bg-cream-dark py-20 md:py-24 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-5 mb-12">
        <span class="font-heading text-6xl md:text-7xl text-gold leading-none">{methodAwakening.num}</span>
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-semibold text-deep-blue">{methodAwakening.title}</h2>
          <p class="text-gold-ink text-sm uppercase tracking-wide font-semibold mt-1">{methodAwakening.subtitle}</p>
        </div>
      </div>
      <p class="text-body-light leading-relaxed max-w-2xl mb-10">{methodAwakening.intro}</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {methodAwakening.items.map((it, i) => (
          <div class="bg-white rounded-card border border-oat-border/60 p-7 shadow-card">
            <div class="w-10 h-10 rounded-full bg-royal text-white text-sm font-semibold flex items-center justify-center mb-4">{i + 1}</div>
            <h3 class="font-heading text-xl font-semibold text-deep-blue mb-2">{it.name}</h3>
            <p class="text-body-light text-sm leading-relaxed">{it.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7 - Life Transformation -->
  <section id="transformation" class="bg-cream py-20 md:py-24 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-5 mb-12">
        <span class="font-heading text-6xl md:text-7xl text-gold leading-none">{methodTransformation.num}</span>
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-semibold text-deep-blue">{methodTransformation.title}</h2>
          <p class="text-gold-ink text-sm uppercase tracking-wide font-semibold mt-1">A holistic awakening across every dimension of life</p>
        </div>
      </div>
      <p class="text-body-light leading-relaxed max-w-2xl mb-10">{methodTransformation.intro}</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {methodTransformation.items.map((it, i) => (
          <div class="flex gap-4 bg-white rounded-card border border-oat-border/60 p-6 shadow-card">
            <span class="font-heading text-3xl text-gold leading-none shrink-0">{i + 1}</span>
            <div>
              <h3 class="font-heading text-lg font-semibold text-deep-blue mb-1">{it.name}</h3>
              <p class="text-body-light text-sm leading-relaxed">{it.body}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-14">
        <a href="/programs" class="inline-flex items-center justify-center bg-royal text-white px-8 py-4 rounded-full text-sm font-semibold uppercase tracking-wide hover:bg-royal-mid transition-all">
          Explore the Programs
        </a>
      </div>
    </div>
  </section>

  <Footer wa={wa} email={email} fb={social.fb} ig={social.ig} yt={social.yt} tt={social.tt} />
  <WhatsAppBar wa={wa} />
</Layout>
